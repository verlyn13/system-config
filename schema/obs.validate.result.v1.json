{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.local/schemas/obs.validate.result.v1.json",
  "title": "ObsValidateResult",
  "type": "object",
  "additionalProperties": false,
  "required": ["ok","registry","dirs","projects_total","projects_with_observations","projects_without_observations"],
  "properties": {
    "ok": { "type": "boolean" },
    "telemetry": {
      "type": ["object","null"],
      "additionalProperties": false,
      "properties": {
        "reachable": { "type": ["boolean","null"] }
      }
    },
    "registry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path","exists"],
      "properties": {
        "path": { "type": "string" },
        "exists": { "type": "boolean" }
      }
    },
    "dirs": { "type": "array", "items": { "type": "string" } },
    "projects_total": { "type": "integer", "minimum": 0 },
    "projects_with_observations": { "type": "integer", "minimum": 0 },
    "projects_without_observations": { "type": "integer", "minimum": 0 }
  }
}

