{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.local/schemas/obs.manifest.result.v1.json",
  "title": "ProjectManifestValidationResult",
  "type": "object",
  "additionalProperties": false,
  "required": ["path","valid","manifest","checkedAt"],
  "properties": {
    "path": { "type": "string" },
    "valid": { "type": ["boolean","null"] },
    "errors": { "type": ["array","null"], "items": { "type": "object" } },
    "manifest": { "$ref": "https://contracts.local/schemas/project.manifest.v1.json" },
    "checkedAt": { "type": "number" }
  }
}
