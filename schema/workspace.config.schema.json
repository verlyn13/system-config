{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://devops.local/schemas/workspace.config.v2.json",
  "title": "Workspace Configuration",
  "description": "Defines workspaces, profiles, and project discovery settings",
  "type": "object",
  "required": ["apiVersion", "kind", "workspaces", "defaults"],
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "workspace.v2"
    },
    "kind": {
      "type": "string",
      "const": "WorkspaceConfig"
    },
    "workspaces": {
      "type": "object",
      "description": "Named workspace definitions",
      "patternProperties": {
        "^[a-z][a-z0-9-]*$": {
          "$ref": "#/definitions/workspace"
        }
      }
    },
    "defaults": {
      "$ref": "#/definitions/defaults"
    },
    "policies": {
      "$ref": "#/definitions/policies"
    },
    "hooks": {
      "$ref": "#/definitions/hooks"
    },
    "telemetry": {
      "$ref": "#/definitions/telemetry"
    }
  },
  "definitions": {
    "workspace": {
      "type": "object",
      "required": ["root", "profile", "tier"],
      "properties": {
        "root": {
          "type": "string",
          "description": "Root directory path (~ expansion supported)"
        },
        "profile": {
          "type": "string",
          "description": "Mise/DS profile name"
        },
        "github": {
          "type": "string",
          "description": "GitHub account name"
        },
        "gitlab": {
          "type": "string",
          "description": "GitLab account name"
        },
        "tier": {
          "type": "string",
          "enum": ["production", "staging", "development", "archive"],
          "description": "Workspace tier/environment"
        },
        "discovery": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            },
            "depth": {
              "type": "integer",
              "minimum": 1,
              "maximum": 10,
              "default": 3
            },
            "patterns": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Glob patterns for discovery"
            },
            "exclude": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Paths to exclude from discovery"
            }
          }
        },
        "toolchains": {
          "type": "object",
          "properties": {
            "mise": {
              "type": "object",
              "properties": {
                "profiles": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "autoInstall": {
                  "type": "boolean",
                  "default": false
                }
              }
            },
            "ds": {
              "type": "object",
              "properties": {
                "context": {
                  "type": "string"
                },
                "server": {
                  "type": "string",
                  "format": "uri"
                },
                "autoConnect": {
                  "type": "boolean",
                  "default": false
                }
              }
            },
            "env": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        },
        "observability": {
          "type": "object",
          "properties": {
            "observers": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["repo", "deps", "build", "quality", "security", "sbom"]
              }
            },
            "schedule": {
              "type": "string",
              "description": "Cron expression for observation schedule"
            },
            "slo": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          }
        },
        "security": {
          "type": "object",
          "properties": {
            "secretsProvider": {
              "type": "string",
              "enum": ["gopass", "vault", "1password", "aws-secrets"]
            },
            "keyringPath": {
              "type": "string"
            },
            "requireSigning": {
              "type": "boolean",
              "default": false
            }
          }
        }
      }
    },
    "defaults": {
      "type": "object",
      "required": ["discoveryDepth", "autoRegister", "validateManifests"],
      "properties": {
        "discoveryDepth": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10,
          "default": 3
        },
        "autoRegister": {
          "type": "boolean",
          "default": true
        },
        "validateManifests": {
          "type": "boolean",
          "default": true
        },
        "requireSigning": {
          "type": "boolean",
          "default": false
        },
        "toolVersions": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "policies": {
      "type": "object",
      "properties": {
        "maxProjectsPerWorkspace": {
          "type": "integer",
          "minimum": 1,
          "default": 100
        },
        "requireManifest": {
          "type": "boolean",
          "default": false
        },
        "requireGit": {
          "type": "boolean",
          "default": true
        },
        "allowedTiers": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["production", "staging", "development", "archive"]
          }
        },
        "forbiddenPaths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "toolchains": {
          "type": "object",
          "properties": {
            "required": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "recommended": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "optional": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "hooks": {
      "type": "object",
      "properties": {
        "preDiscovery": {
          "type": "string"
        },
        "postDiscovery": {
          "type": "string"
        },
        "preValidation": {
          "type": "string"
        },
        "onError": {
          "type": "string"
        }
      }
    },
    "telemetry": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "endpoint": {
          "type": "string",
          "format": "uri"
        },
        "attributes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "metrics": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}