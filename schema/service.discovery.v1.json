{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.local/schemas/service.discovery.v1.json",
  "title": "ServiceDiscovery",
  "type": "object",
  "additionalProperties": false,
  "required": ["ts"],
  "properties": {
    "ds": {
      "type": ["object","null"],
      "additionalProperties": false,
      "properties": {
        "url": { "type": "string", "format": "uri" },
        "well_known": { "type": "string", "format": "uri" },
        "openapi": { "type": "string", "format": "uri" },
        "capabilities": { "type": "string", "format": "uri" },
        "health": { "type": "string", "format": "uri" },
        "self_status": { "type": "string", "format": "uri" }
      }
    },
    "mcp": {
      "type": ["object","null"],
      "additionalProperties": false,
      "properties": {
        "url": { "type": "string", "format": "uri" },
        "openapi": { "type": "string", "format": "uri" },
        "self_status": { "type": "string", "format": "uri" }
      }
    },
    "registry": { "type": ["object","null"] },
    "ds_token_present": { "type": "boolean" },
    "ts": { "type": "number" }
  }
}
