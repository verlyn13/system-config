{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.local/schemas/obs.slobreach.v1.json",
  "title": "SLOBreachEvent",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion","type","timestamp","project_id","slo","threshold","details"],
  "properties": {
    "apiVersion": { "const": "obs.v1" },
    "type": { "const": "SLOBreach" },
    "timestamp": { "type": "string", "format": "date-time" },
    "project_id": { "type": "string", "pattern": "^[a-z]+:[a-z0-9-]+/[a-z0-9-]+$" },
    "slo": { "type": "string" },
    "threshold": { "type": "string" },
    "details": { "$ref": "https://contracts.local/schemas/obs.health.v1.json" }
  }
}

