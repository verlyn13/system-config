{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.local/schemas/project.manifest.v1.json",
  "title": "ProjectManifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "project"],
  "properties": {
    "apiVersion": { "const": "devops.v1" },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "org", "tier", "kind", "owners"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z]+:[a-z0-9-]+/[a-z0-9-]+$" },
        "name": { "type": "string", "minLength": 1, "maxLength": 100 },
        "org": { "type": "string", "minLength": 1, "maxLength": 50 },
        "tier": { "type": "string", "enum": ["prod","staging","sandbox","dev"] },
        "kind": { "type": "string", "enum": ["app","lib","ml","data","infra","docs"] },
        "owners": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "format": "email" }
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["language"],
      "properties": {
        "language": { "type": "string", "enum": ["node","python","go","rust","java","multi"] },
        "miseProfiles": { "type": "array", "items": { "type": "string" } }
      }
    },
    "repo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url"],
      "properties": {
        "url": { "type": "string", "format": "uri" },
        "defaultBranch": { "type": "string" },
        "protectedBranches": { "type": "array", "items": { "type": "string" } },
        "signedCommitsRequired": { "type": "boolean" }
      }
    },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "minCoverage": { "type": "number", "minimum": 0, "maximum": 1 },
        "linters": { "type": "array", "items": { "type": "string" } },
        "licensesAllow": { "type": "array", "items": { "type": "string" } },
        "sbom": { "type": "boolean" }
      }
    },
    "observability": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "slo": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "ciSuccessRate": { "type": "string", "pattern": "^[><=]+[\\d.]+$" },
            "p95LocalBuildSec": { "type": "string", "pattern": "^[><=]+[\\d.]+$" }
          }
        },
        "metrics": {
          "type": "object",
          "additionalProperties": false,
          "properties": { "enableBusiness": { "type": "boolean" } }
        },
        "alerts": {
          "type": "object",
          "additionalProperties": false,
          "properties": { "channel": { "type": "string" } }
        }
      }
    },
    "dependencies": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "packageManagers": { "type": "array", "items": { "type": "string", "enum": ["npm","pip","cargo","go","mix","gem","maven"] } },
        "updatePolicy": { "type": "string", "enum": ["daily","weekly","monthly"] }
      }
    },
    "security": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "secretRefs": { "type": "array", "items": { "type": "string", "pattern": "^secret://gopass/.*" } },
        "owaspLevel": { "type": "string", "enum": ["L1","L2","L3"] }
      }
    },
    "dashboard": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "panels": { "type": "array", "items": { "type": "string", "enum": ["buildHealth","coverage","deps","repoStatus","obsLatency","sloCompliance"] } }
      }
    }
  }
}

