{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.local/schemas/obs.integration.v1.json",
  "title": "ProjectIntegration",
  "type": "object",
  "additionalProperties": false,
  "required": ["contractVersion","schemaVersion","project","observers","health","services","timestamp","checkedAt"],
  "properties": {
    "contractVersion": { "type": "string" },
    "schemaVersion": { "const": "obs.v1" },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id","name","org","tier","kind","path"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z]+:[a-z0-9-]+/[a-z0-9-]+$" },
        "name": { "type": "string" },
        "org": { "type": "string" },
        "tier": { "type": "string" },
        "kind": { "type": "string" },
        "path": { "type": "string" },
        "manifest_present": { "type": "boolean" }
      }
    },
    "observers": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "count": { "type": "integer", "minimum": 0 },
          "latest": { "$ref": "https://contracts.local/schemas/obs.line.v1.json" }
        }
      }
    },
    "health": { "$ref": "https://contracts.local/schemas/obs.health.v1.json" },
    "services": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ds": {
          "type": ["object","null"],
          "additionalProperties": false,
          "properties": {
            "url": { "type": "string", "format": "uri" },
            "reachable": { "type": "boolean" },
            "capabilities": { "type": ["object","null"] },
            "health": { "type": ["object","null"] },
            "self_status": { "type": ["object","null"] }
          }
        },
        "mcp": {
          "type": ["object","null"],
          "additionalProperties": false,
          "properties": {
            "url": { "type": "string", "format": "uri" },
            "reachable": { "type": "boolean" },
            "self_status": { "type": ["object","null"] }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string" },
        "detectors": { "type": "array", "items": { "type": "string" } },
        "registryPath": { "type": "string" },
        "registryPresent": { "type": "boolean" },
        "manifestValid": { "type": "boolean" },
        "ready": { "type": "boolean" }
      }
    },
    "timestamp": { "type": "string", "format": "date-time" },
    "checkedAt": { "type": "number" }
  }
}
