# Environment and secrets
.env
.env.*
.envrc.local

# Editor and IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Temp and backup files
*.bak
*.tmp
*.log
tmp/

# Claude Code
.claude/logs/
.claude/cache/
.claude/*.log
.claude/settings.local.json
.claude/worktrees/

# Gemini
.gemini/tmp/

# Legacy artifacts (should not reappear)
node_modules/
package-lock.json
.nvmrc
.node-version

# Working reference material for in-flight migrations (not committed)
github-mcp-docs/

# Device-admin live-host evidence directories
# (e.g. docs/device-admin/<device>-baseline-yyyymmddThhmmssZ/).
# Per docs/device-admin/windows-terminal-admin-spec.md, raw evidence
# stays outside the repo. This pattern prevents accidental commits if
# an operator copies an evidence dir into the working tree for review.
# Apply records (*.md) are unaffected; they belong in git.
docs/device-admin/*-[0-9]*T[0-9]*Z/
