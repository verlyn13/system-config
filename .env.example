# Bridge (HTTP) configuration
OBS_BRIDGE_URL=http://127.0.0.1:7171
BRIDGE_AUTO_DISCOVER=1
# Set to secure local endpoints (optional)
# BRIDGE_TOKEN=change-me

# DS CLI (ds-go) configuration
DS_BASE_URL=http://127.0.0.1:7777
DS_TOKEN=

# Discovery roots (comma-separated, optional)
DEVOPS_MCP_ROOTS=$HOME/Development/personal,$HOME/Development/work,$HOME/Development/business,$HOME/workspace/projects
