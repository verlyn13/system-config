{
  "name": "system-setup-update bridge",
  "contractVersion": "v1.1.0",
  "schemaVersion": "obs.v1",
  "defaults": {
    "ports": { "bridge": 7171, "mcp": 4319, "ds": 7777 },
    "env": {
      "bridge": ["OBS_BRIDGE_URL"],
      "mcp": ["MCP_URL", "MCP_BASE_URL"],
      "ds": ["DS_BASE_URL"]
    }
  },
  "endpoints": {
    "health": "/api/health",
    "telemetry": "/api/telemetry-info",
    "openapi": "/openapi.yaml",
    "schemas": "/api/discovery/schemas",
    "registry": "/api/discovery/registry",
    "projects": "/api/projects",
    "projectStatus": "/api/projects/{id}/status",
    "projectHealth": "/api/projects/{id}/health",
    "projectIntegration": "/api/projects/{id}/integration",
    "events": "/api/events/stream",
    "discover": "/api/discover",
    "obsRun": "/api/tools/project_obs_run"
  }
}
