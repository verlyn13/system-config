#!/usr/bin/env bash
set -euo pipefail

echo "[chezmoi] Installing Tailscale via official .pkg installer"

have() { command -v "$1" >/dev/null 2>&1; }

# Check if already installed
TAILSCALE_CLI="/Applications/Tailscale.app/Contents/MacOS/tailscale"
if [[ -x "$TAILSCALE_CLI" ]]; then
  current_version=$("$TAILSCALE_CLI" version 2>/dev/null | head -1 | awk '{print $1}' || echo "unknown")
  echo "[chezmoi] Tailscale already installed (${current_version})"
  echo "[chezmoi] To update, download the latest .pkg from: https://tailscale.com/download/macos"
  exit 0
fi

# Get latest version from Tailscale stable channel
echo "[chezmoi] Fetching latest Tailscale version..."
LATEST_VERSION=$(curl -fsSL https://pkgs.tailscale.com/stable/ | grep -o 'Tailscale-[0-9]\+\.[0-9]\+\.[0-9]\+-macos\.pkg' | head -1 | sed 's/Tailscale-\(.*\)-macos\.pkg/\1/')

if [[ -z "$LATEST_VERSION" ]]; then
  echo "[chezmoi] ERROR: Could not determine latest Tailscale version"
  echo "[chezmoi] Install manually from: https://tailscale.com/download/macos"
  exit 1
fi

echo "[chezmoi] Latest version: ${LATEST_VERSION}"

# Download the .pkg installer
PKG_URL="https://pkgs.tailscale.com/stable/Tailscale-${LATEST_VERSION}-macos.pkg"
TMP_PKG="/tmp/Tailscale-${LATEST_VERSION}-macos.pkg"

echo "[chezmoi] Downloading from: ${PKG_URL}"
if ! curl -fsSL -o "$TMP_PKG" "$PKG_URL"; then
  echo "[chezmoi] ERROR: Download failed"
  echo "[chezmoi] Install manually from: https://tailscale.com/download/macos"
  exit 1
fi

# Install the package
echo "[chezmoi] Installing Tailscale ${LATEST_VERSION}..."
if ! sudo installer -pkg "$TMP_PKG" -target /; then
  echo "[chezmoi] ERROR: Installation failed"
  rm -f "$TMP_PKG"
  exit 1
fi

# Clean up
rm -f "$TMP_PKG"
echo "[chezmoi] Temporary package removed"

# Verify installation
if [[ -x "$TAILSCALE_CLI" ]]; then
  version=$("$TAILSCALE_CLI" version 2>/dev/null | head -1 | awk '{print $1}' || echo "unknown")
  echo "[chezmoi] ✓ Tailscale ${version} installed"
  echo "[chezmoi] Location: ${TAILSCALE_CLI}"
  echo "[chezmoi]"
  echo "[chezmoi] IMPORTANT: System Extension Approval Required"
  echo "[chezmoi]   1. Open System Settings (⚙️)"
  echo "[chezmoi]   2. Go to Privacy & Security"
  echo "[chezmoi]   3. Scroll to Security section"
  echo "[chezmoi]   4. Click 'Allow' for Tailscale system extension"
  echo "[chezmoi]   OR: Launch Tailscale.app from Applications to trigger approval"
  echo "[chezmoi]"
  echo "[chezmoi] Configuration:"
  echo "[chezmoi]   - GUI Application: /Applications/Tailscale.app"
  echo "[chezmoi]   - CLI binary: ${TAILSCALE_CLI}"
  echo "[chezmoi]   - Fish shell adds CLI to PATH automatically"
  echo "[chezmoi]   - Docs: https://tailscale.com/kb/"
  echo "[chezmoi]"
  echo "[chezmoi] Quick start (after approving system extension):"
  echo "[chezmoi]   - 'sudo tailscale up' - Connect to your network"
  echo "[chezmoi]   - 'tailscale status' - Check connection status"
  echo "[chezmoi]   - 'tailscale ip' - Show your Tailscale IPs"
  echo "[chezmoi]   - 'tailscale_status' - Show detailed status (Fish)"
  echo "[chezmoi]"
  echo "[chezmoi] Fish shell aliases available:"
  echo "[chezmoi]   - 'tsup' / 'tsdown' - Connect/disconnect"
  echo "[chezmoi]   - 'tsstatus' - Status"
  echo "[chezmoi]   - 'tsip' - Show IPs"
  echo "[chezmoi]   - 'tsping <device>' - Ping a device"
  echo "[chezmoi]   - 'tsopen' - Open Tailscale app"
else
  echo "[chezmoi] WARNING: Installation completed but Tailscale app not found"
  echo "[chezmoi] Expected at: ${TAILSCALE_CLI}"
  echo "[chezmoi] Try:"
  echo "[chezmoi]   1. Open /Applications/Tailscale.app to complete setup"
  echo "[chezmoi]   2. Approve the system extension in System Settings"
  echo "[chezmoi]   3. Restart your shell"
fi
