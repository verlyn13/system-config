#!/usr/bin/env bash
set -euo pipefail

echo "[chezmoi] Installing Sentry CLI via npm"

have() { command -v "$1" >/dev/null 2>&1; }

# Check if already installed
if have sentry-cli; then
  current_version=$(sentry-cli --version 2>/dev/null | grep -o '[0-9]\+\.[0-9]\+\.[0-9]\+' | head -1 || echo "unknown")
  echo "[chezmoi] Sentry CLI already installed (v${current_version})"

  # Check for updates
  if have npm; then
    latest_version=$(npm view @sentry/cli version 2>/dev/null || echo "unknown")
    if [[ "$current_version" != "$latest_version" && "$latest_version" != "unknown" ]]; then
      echo "[chezmoi] Update available: v${current_version} → v${latest_version}"
      echo "[chezmoi] Run: npm update -g @sentry/cli"
    fi
  fi
  exit 0
fi

# Ensure npm is available
if ! have npm; then
  echo "[chezmoi] ERROR: npm not found. Install Node.js/npm first."
  echo "[chezmoi] Run: brew install node"
  exit 1
fi

# Install Sentry CLI from npm
echo "[chezmoi] Installing @sentry/cli globally..."
npm install -g @sentry/cli

if have sentry-cli; then
  version=$(sentry-cli --version 2>/dev/null | grep -o '[0-9]\+\.[0-9]\+\.[0-9]\+' | head -1)
  echo "[chezmoi] ✓ Sentry CLI v${version} installed"
  echo "[chezmoi] Location: $(which sentry-cli)"
  echo "[chezmoi]"
  echo "[chezmoi] Configuration:"
  echo "[chezmoi]   - Set SENTRY_AUTH_TOKEN, SENTRY_ORG, SENTRY_PROJECT in .envrc"
  echo "[chezmoi]   - Or store auth token in gopass: gopass insert sentry/auth-token"
  echo "[chezmoi]   - Run: sentry-cli login (for interactive setup)"
  echo "[chezmoi]   - Docs: https://docs.sentry.io/cli/"
else
  echo "[chezmoi] WARNING: Installation completed but 'sentry-cli' command not found in PATH"
  echo "[chezmoi] Check ~/.npm-global/bin is in your PATH"
fi
