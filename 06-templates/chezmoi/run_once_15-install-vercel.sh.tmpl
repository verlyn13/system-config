#!/usr/bin/env bash
set -euo pipefail

echo "[chezmoi] Installing Vercel CLI via npm"

have() { command -v "$1" >/dev/null 2>&1; }

# Check if already installed
if have vercel; then
  current_version=$(vercel --version 2>/dev/null | grep -o '[0-9]\+\.[0-9]\+\.[0-9]\+' | head -1 || echo "unknown")
  echo "[chezmoi] Vercel CLI already installed (v${current_version})"

  # Check for updates
  if have npm; then
    latest_version=$(npm view vercel version 2>/dev/null || echo "unknown")
    if [[ "$current_version" != "$latest_version" && "$latest_version" != "unknown" ]]; then
      echo "[chezmoi] Update available: v${current_version} → v${latest_version}"
      echo "[chezmoi] Run: npm update -g vercel"
    fi
  fi
  exit 0
fi

# Ensure npm is available
if ! have npm; then
  echo "[chezmoi] ERROR: npm not found. Install Node.js/npm first."
  echo "[chezmoi] Run: brew install node"
  exit 1
fi

# Install Vercel CLI from npm
echo "[chezmoi] Installing vercel globally..."
npm install -g vercel

if have vercel; then
  version=$(vercel --version 2>/dev/null | grep -o '[0-9]\+\.[0-9]\+\.[0-9]\+' | head -1)
  echo "[chezmoi] ✓ Vercel CLI v${version} installed"
  echo "[chezmoi] Location: $(which vercel)"
  echo "[chezmoi]"
  echo "[chezmoi] Configuration:"
  echo "[chezmoi]   - Run 'vercel login' for interactive authentication"
  echo "[chezmoi]   - Or store token in gopass: gopass insert vercel/token"
  echo "[chezmoi]   - Set VERCEL_TOKEN in .envrc for CI/CD use"
  echo "[chezmoi]   - Link projects with: vercel link"
  echo "[chezmoi]   - Docs: https://vercel.com/docs/cli"
else
  echo "[chezmoi] WARNING: Installation completed but 'vercel' command not found in PATH"
  echo "[chezmoi] Check ~/.npm-global/bin is in your PATH"
fi
