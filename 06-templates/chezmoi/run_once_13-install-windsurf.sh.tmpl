#!/usr/bin/env bash
set -euo pipefail

echo "[chezmoi] Installing Windsurf AI IDE via Homebrew"

have() { command -v "$1" >/dev/null 2>&1; }

# Check if already installed
if test -d /Applications/Windsurf.app; then
  version=$(defaults read /Applications/Windsurf.app/Contents/Info.plist CFBundleShortVersionString 2>/dev/null || echo "unknown")
  echo "[chezmoi] Windsurf already installed (v${version})"

  # Check for updates via Homebrew
  if have brew; then
    echo "[chezmoi] Checking for updates..."
    brew info --cask windsurf | grep -E "windsurf:" | head -1 || true
  fi
  exit 0
fi

# Ensure Homebrew is available
if ! have brew; then
  echo "[chezmoi] ERROR: Homebrew not found. Install Homebrew first."
  echo "[chezmoi] Visit: https://brew.sh"
  exit 1
fi

# Install Windsurf via Homebrew cask
echo "[chezmoi] Installing windsurf cask..."
brew install --cask windsurf

if test -d /Applications/Windsurf.app; then
  version=$(defaults read /Applications/Windsurf.app/Contents/Info.plist CFBundleShortVersionString 2>/dev/null || echo "unknown")
  echo "[chezmoi] ✓ Windsurf v${version} installed"
  echo "[chezmoi] Location: /Applications/Windsurf.app"

  # Check for CLI binary
  cli_bin="/Applications/Windsurf.app/Contents/Resources/app/bin/windsurf"
  if test -x "$cli_bin"; then
    echo "[chezmoi] ✓ CLI available: $cli_bin"
    echo "[chezmoi] Fish shell will add it to PATH via 13-windsurf.fish"
  else
    echo "[chezmoi] WARNING: CLI binary not found at expected location"
  fi
else
  echo "[chezmoi] WARNING: Installation completed but Windsurf.app not found"
  echo "[chezmoi] Check: brew list --cask windsurf"
fi

echo "[chezmoi] Next steps:"
echo "[chezmoi]   1. Launch Windsurf from Applications or run: open -a Windsurf"
echo "[chezmoi]   2. Sign up for Codeium account (free credits available)"
echo "[chezmoi]   3. Use 'windsurf .' or 'ws .' to open projects from terminal"
