#!/usr/bin/env bash
set -euo pipefail

echo "[chezmoi] Installing Infisical CLI via Homebrew"

have() { command -v "$1" >/dev/null 2>&1; }

# Check if already installed
if have infisical; then
  current_version=$(infisical --version 2>/dev/null | grep -o '[0-9]\+\.[0-9]\+\.[0-9]\+' | head -1 || echo "unknown")
  echo "[chezmoi] Infisical CLI already installed (v${current_version})"

  # Check for updates
  if have brew; then
    latest_version=$(brew info infisical 2>/dev/null | grep -o 'stable [0-9]\+\.[0-9]\+\.[0-9]\+' | cut -d' ' -f2 || echo "unknown")
    if [[ "$current_version" != "$latest_version" && "$latest_version" != "unknown" ]]; then
      echo "[chezmoi] Update available: v${current_version} → v${latest_version}"
      echo "[chezmoi] Run: brew upgrade infisical"
    fi
  fi
  exit 0
fi

# Ensure Homebrew is available
if ! have brew; then
  echo "[chezmoi] ERROR: Homebrew not found. Install Homebrew first."
  echo "[chezmoi] Visit: https://brew.sh"
  exit 1
fi

# Install Infisical CLI from Homebrew
echo "[chezmoi] Installing infisical..."
brew install infisical

if have infisical; then
  version=$(infisical --version 2>/dev/null | grep -o '[0-9]\+\.[0-9]\+\.[0-9]\+' | head -1)
  echo "[chezmoi] ✓ Infisical CLI v${version} installed"
  echo "[chezmoi] Location: $(which infisical)"
  echo "[chezmoi]"
  echo "[chezmoi] Configuration:"
  echo "[chezmoi]   - Self-hosted instance: https://infisical.jefahnierocks.com"
  echo "[chezmoi]   - Run 'infisical-login' to authenticate"
  echo "[chezmoi]   - Use 'trinity-context' to switch between personal/litecky/happy"
  echo "[chezmoi]   - Store machine credentials: gopass insert trinity/<context>/client_id"
  echo "[chezmoi]   - Docs: https://infisical.com/docs/cli/overview"
else
  echo "[chezmoi] WARNING: Installation completed but 'infisical' command not found in PATH"
  echo "[chezmoi] Try restarting your shell"
fi
