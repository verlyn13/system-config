#!/usr/bin/env bash
set -euo pipefail

echo "[chezmoi] Installing OrbStack via Homebrew"

have() { command -v "$1" >/dev/null 2>&1; }

# Check if already installed
if have orb; then
  current_version=$(orb version 2>/dev/null | head -1 | grep -o '[0-9]\+\.[0-9]\+\.[0-9]\+' || echo "unknown")
  echo "[chezmoi] OrbStack already installed (v${current_version})"

  # Check for updates
  if have brew; then
    latest_info=$(brew info --cask orbstack 2>/dev/null | grep -E '^orbstack:' || echo "")
    if [[ -n "$latest_info" ]]; then
      latest_version=$(echo "$latest_info" | grep -o '[0-9]\+\.[0-9]\+\.[0-9]\+' | head -1 || echo "unknown")
      if [[ "$current_version" != "$latest_version" && "$latest_version" != "unknown" ]]; then
        echo "[chezmoi] Update available: v${current_version} → v${latest_version}"
        echo "[chezmoi] Run: brew upgrade --cask orbstack"
      fi
    fi
  fi
  exit 0
fi

# Ensure Homebrew is available
if ! have brew; then
  echo "[chezmoi] ERROR: Homebrew not found. Install Homebrew first."
  echo "[chezmoi] Visit: https://brew.sh"
  exit 1
fi

# Install OrbStack from Homebrew cask
echo "[chezmoi] Installing orbstack cask..."
brew install --cask orbstack

# Verify installation
if have orb; then
  version=$(orb version 2>/dev/null | head -1 | grep -o '[0-9]\+\.[0-9]\+\.[0-9]\+' || echo "unknown")
  echo "[chezmoi] ✓ OrbStack v${version} installed"
  echo "[chezmoi] Location: $(which orb)"
  echo "[chezmoi]"
  echo "[chezmoi] Configuration:"
  echo "[chezmoi]   - GUI Application: /Applications/OrbStack.app"
  echo "[chezmoi]   - CLI binaries: orb, orbctl, docker, docker-compose"
  echo "[chezmoi]   - Open OrbStack.app to complete setup"
  echo "[chezmoi]   - Fish completions auto-loaded from app bundle"
  echo "[chezmoi]   - Docs: https://docs.orbstack.dev/"
  echo "[chezmoi]"
  echo "[chezmoi] Quick start:"
  echo "[chezmoi]   - 'orb start' - Start OrbStack"
  echo "[chezmoi]   - 'orb status' - Check status"
  echo "[chezmoi]   - 'docker ps' - List running containers"
  echo "[chezmoi]   - 'orbstack_status' - Show detailed status (Fish)"
else
  echo "[chezmoi] WARNING: Installation completed but 'orb' command not found in PATH"
  echo "[chezmoi] Try:"
  echo "[chezmoi]   1. Open /Applications/OrbStack.app to complete setup"
  echo "[chezmoi]   2. Restart your shell"
fi
