# Standard project .envrc (chezmoi template)
# - Robust mise integration with direnv
# - Safe dotenv loading

# Load mise integration and activate tools (no external calls)
use_mise() {
  direnv_load mise direnv exec
}
use mise

# PATH additions for common local bins
PATH_add bin
PATH_add node_modules/.bin

# Load environment files if present (safe, non-fatal)
dotenv_if_exists .env.local
dotenv_if_exists .env

# Optional: uncomment to set a default NODE_ENV
# export NODE_ENV=development
