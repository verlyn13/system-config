{{- /* Tmux configuration (chezmoi-managed) */ -}}
{{- /* Pro-level modern setup for Option B: Pure Tmux workflow */ -}}
# ============================================================================
# Tmux Configuration ({{ .chezmoi.hostname }})
# Last updated: {{ now | date "2006-01-02" }}
# Managed by: chezmoi
# ============================================================================
# This configuration is optimized for:
# - Option B: Pure Tmux workflow (no iTerm2 native integration)
# - Modern terminals with True Color support
# - Fish shell integration
# - Beautiful, productive, and portable configuration
# ============================================================================

# ============================================================================
# TERMINAL & COLOR SUPPORT
# ============================================================================

# Enable True Color (24-bit) support for modern terminals
set-option -sa terminal-overrides ",xterm*:Tc"
set-option -sa terminal-overrides ",screen*:Tc"
set-option -sa terminal-overrides ",tmux*:Tc"

# Enable RGB capability
set-option -sa terminal-features ",xterm*:RGB"
set-option -sa terminal-features ",screen*:RGB"
set-option -sa terminal-features ",tmux*:RGB"

# Set default terminal to 256 colors
set -g default-terminal "tmux-256color"

# ============================================================================
# MOUSE SUPPORT
# ============================================================================

# Enable mouse mode (tmux 2.1+)
# - Click to select panes
# - Drag to resize panes
# - Scroll with mouse wheel
# - Select and copy text with mouse
set -g mouse on

# ============================================================================
# PREFIX KEY
# ============================================================================

# Change prefix from 'C-b' to 'C-a' (closer to home row, easier to reach)
unbind C-b
set -g prefix C-a
bind C-a send-prefix

# ============================================================================
# SHELL CONFIGURATION
# ============================================================================

# Use Fish shell by default (Homebrew installation path)
{{- if eq .chezmoi.os "darwin" }}
set-option -g default-shell /opt/homebrew/bin/fish
{{- else }}
set-option -g default-shell /usr/bin/fish
{{- end }}

# ============================================================================
# WINDOW & PANE INDEXING
# ============================================================================

# Start windows and panes at 1, not 0 (easier to reach on keyboard)
set -g base-index 1
setw -g pane-base-index 1

# Renumber windows when one is closed
set -g renumber-windows on

# ============================================================================
# WINDOW & PANE SPLITTING
# ============================================================================

# Split panes using | and - (visual mnemonics, easier to remember)
bind | split-window -h -c "#{pane_current_path}"
bind - split-window -v -c "#{pane_current_path}"
unbind '"'
unbind %

# New window in current path
bind c new-window -c "#{pane_current_path}"

# ============================================================================
# PANE NAVIGATION (VIM-STYLE)
# ============================================================================

# Switch panes using hjkl (vim-style)
bind h select-pane -L
bind j select-pane -D
bind k select-pane -U
bind l select-pane -R

# Switch windows using Alt+arrow keys (without prefix)
bind -n M-Left previous-window
bind -n M-Right next-window

# Swap windows
bind -r "<" swap-window -d -t -1
bind -r ">" swap-window -d -t +1

# ============================================================================
# PANE RESIZING
# ============================================================================

# Resize panes using Prefix + Arrow keys
bind -r Left resize-pane -L 5
bind -r Down resize-pane -D 5
bind -r Up resize-pane -U 5
bind -r Right resize-pane -R 5

# ============================================================================
# COPY MODE (VIM-STYLE)
# ============================================================================

# Use vim keybindings in copy mode
setw -g mode-keys vi

# Setup 'v' to begin selection as in Vim
bind -T copy-mode-vi v send -X begin-selection
bind -T copy-mode-vi y send -X copy-selection-and-cancel

{{- if eq .chezmoi.os "darwin" }}
# macOS: Copy to system clipboard using pbcopy
bind -T copy-mode-vi y send -X copy-pipe-and-cancel "pbcopy"
bind -T copy-mode-vi MouseDragEnd1Pane send -X copy-pipe-and-cancel "pbcopy"
{{- else }}
# Linux: Copy to system clipboard using xclip
bind -T copy-mode-vi y send -X copy-pipe-and-cancel "xclip -in -selection clipboard"
bind -T copy-mode-vi MouseDragEnd1Pane send -X copy-pipe-and-cancel "xclip -in -selection clipboard"
{{- end }}

# Enter copy mode with Prefix + [
bind [ copy-mode

# Paste with Prefix + ]
bind ] paste-buffer

# ============================================================================
# RELOAD CONFIGURATION
# ============================================================================

# Reload config file with Prefix + r
bind r source-file ~/.tmux.conf \; display "Config reloaded!"

# ============================================================================
# WINDOW MONITORING
# ============================================================================

# Monitor for activity in windows
setw -g monitor-activity on
set -g visual-activity off  # Don't show message, just highlight in status bar

# ============================================================================
# STATUS BAR CONFIGURATION
# ============================================================================

# Status bar position (top is more modern, bottom is traditional)
{{- if eq (.tmux_status_position | default "top") "top" }}
set -g status-position top
{{- else }}
set -g status-position bottom
{{- end }}

# Update status bar every second
set -g status-interval 1

# Status bar length
set -g status-left-length 50
set -g status-right-length 100

# ============================================================================
# STATUS BAR THEME (Catppuccin Mocha)
# ============================================================================
# Colors from Catppuccin Mocha palette
# https://github.com/catppuccin/catppuccin

# Base colors
set -g status-style 'bg=#1e1e2e fg=#cdd6f4'

# Window status
setw -g window-status-style 'fg=#7f849c bg=#1e1e2e'
setw -g window-status-format ' #I:#W '

setw -g window-status-current-style 'fg=#1e1e2e bg=#89b4fa bold'
setw -g window-status-current-format ' #I:#W '

# Window with activity
setw -g window-status-activity-style 'fg=#f38ba8 bg=#1e1e2e'

# Pane borders
set -g pane-border-style 'fg=#313244'
set -g pane-active-border-style 'fg=#89b4fa'

# Message text
set -g message-style 'fg=#cdd6f4 bg=#313244'
set -g message-command-style 'fg=#cdd6f4 bg=#313244'

# ============================================================================
# STATUS BAR CONTENT
# ============================================================================

# Left status bar: Session name and window list
set -g status-left '#[fg=#1e1e2e,bg=#89b4fa,bold] #S #[fg=#89b4fa,bg=#1e1e2e] '

# Right status bar: System info
{{- if eq .chezmoi.os "darwin" }}
# macOS: Show hostname, CPU, battery, date/time
set -g status-right '#[fg=#7f849c,bg=#1e1e2e] #H #[fg=#cdd6f4,bg=#313244] CPU: #(top -l 1 | grep "CPU usage" | awk "{print \$3}" | sed "s/%//") #[fg=#cdd6f4,bg=#313244] #(pmset -g batt | grep -Eo "[0-9]+%" | head -1) #[fg=#1e1e2e,bg=#a6e3a1,bold] %Y-%m-%d #[fg=#1e1e2e,bg=#89b4fa,bold] %H:%M:%S '
{{- else }}
# Linux: Show hostname, CPU, date/time
set -g status-right '#[fg=#7f849c,bg=#1e1e2e] #H #[fg=#cdd6f4,bg=#313244] CPU: #(cat /proc/loadavg | cut -d" " -f1) #[fg=#1e1e2e,bg=#a6e3a1,bold] %Y-%m-%d #[fg=#1e1e2e,bg=#89b4fa,bold] %H:%M:%S '
{{- end }}

# ============================================================================
# WINDOW TITLE
# ============================================================================

# Set terminal title
set -g set-titles on
set -g set-titles-string '#S:#I:#W - "#{pane_title}"'

# ============================================================================
# PERFORMANCE TUNING
# ============================================================================

# Increase scrollback buffer size
set -g history-limit 50000

# Reduce escape time (important for Vim/Neovim)
set -sg escape-time 10

# Increase repeat time for repeatable commands
set -g repeat-time 600

# Focus events enabled for terminals that support them
set -g focus-events on

# Aggressive resize (only constrain window size if smaller client is viewing)
setw -g aggressive-resize on

# ============================================================================
# NESTED TMUX SUPPORT
# ============================================================================

# Toggle between local and nested tmux with F12
bind -T root F12  \
  set prefix None \;\
  set key-table off \;\
  set status-style "fg=#7f849c,bg=#313244" \;\
  if -F '#{pane_in_mode}' 'send-keys -X cancel' \;\
  refresh-client -S \;\

bind -T off F12 \
  set -u prefix \;\
  set -u key-table \;\
  set -u status-style \;\
  refresh-client -S

# ============================================================================
# PLUGIN MANAGER (TPM)
# ============================================================================
# Tmux Plugin Manager - uncomment to enable
# Install TPM: git clone https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm

# List of plugins
# set -g @plugin 'tmux-plugins/tpm'
# set -g @plugin 'tmux-plugins/tmux-sensible'
# set -g @plugin 'tmux-plugins/tmux-resurrect'   # Save/restore sessions
# set -g @plugin 'tmux-plugins/tmux-continuum'   # Auto-save sessions
# set -g @plugin 'tmux-plugins/tmux-yank'        # Enhanced copy
# set -g @plugin 'catppuccin/tmux'               # Catppuccin theme

# Plugin options
# set -g @resurrect-capture-pane-contents 'on'
# set -g @continuum-restore 'on'

# Initialize TMUX plugin manager (keep this line at the very bottom)
# run '~/.tmux/plugins/tpm/tpm'

# ============================================================================
# CUSTOM KEYBINDINGS
# ============================================================================

# Quick session switching
bind S choose-session

# Kill session
bind X confirm-before -p "kill-session #S? (y/n)" kill-session

# Clear history
bind C-l send-keys 'C-l' \; clear-history

# Synchronize panes (send commands to all panes)
bind s setw synchronize-panes

# ============================================================================
# MACHINE-SPECIFIC OVERRIDES
# ============================================================================

# Load machine-specific tmux configuration if it exists (not managed by chezmoi)
source-file -q ~/.tmux.local.conf
