#!/usr/bin/env fish
# Codex CLI Configuration (managed via chezmoi)
# Single source of truth for Codex CLI commands and configuration
# Installation: brew install openai/openai/codex
# Docs: https://developers.openai.com/codex/cli/

# Codex binary path (set if using local install)
if not set -q CODEX_BIN
    # Default: brew installation; falls back to PATH later
    set -gx CODEX_BIN /opt/homebrew/bin/codex
end

# Codex config file (single file Codex reads; override per-project via CODEX_CONFIG)
if not set -q CODEX_CONFIG
    set -gx CODEX_CONFIG ~/.codex/config.toml
end

# Default profile (override per-project in .envrc)
if not set -q CODEX_PROFILE
    set -gx CODEX_PROFILE "dev"
end

# Sandbox mode (workspace-write is safest default)
if not set -q CODEX_SANDBOX
    set -gx CODEX_SANDBOX "workspace-write"
end

function __codex_exec --description 'Execute Codex CLI'
    if test -x $CODEX_BIN
        command $CODEX_BIN $argv
        return $status
    end

    # Fallback: check PATH for 'codex'
    if type -q codex
        command codex $argv
        return $status
    end

    echo 'codex: CLI not found. Run: brew install openai/openai/codex (or npm install -g @openai/codex)'
    return 127
end

# Public commands
function codex --description 'OpenAI Codex CLI'
    __codex_exec $argv
end

function cx --description 'Codex (quick alias)'
    __codex_exec $argv
end

function cxp --description 'Codex with profile selection'
    set -l profile $argv[1]
    set -l rest $argv[2..-1]
    if test -n "$profile"
        __codex_exec -p $profile $rest
    else
        echo "Usage: cxp <profile> [args...]"
        echo "Profiles: default, speed, deep, agent, maint"
        return 1
    end
end

function cxfast --description 'Codex fast profile'
    __codex_exec -p fast $argv
end

function cxreview --description 'Codex review profile'
    __codex_exec -p review $argv
end

function cxspeed --description 'Codex speed profile (compat alias -> fast)'
    __codex_exec -p fast $argv
end

# Version check helper
function codex_check_updates --description 'Check for Codex CLI updates'
    set -l current (codex --version 2>/dev/null | grep -o '[0-9]\+\.[0-9]\+\.[0-9]\+' | head -1)
    set -l latest (npm view @openai/codex version 2>/dev/null)

    if test -n "$current" -a -n "$latest"
        echo "Current: v$current"
        echo "Latest:  v$latest"
        if test "$current" != "$latest"
            echo ""
            echo "Update available! Run: npm update -g @openai/codex"
        else
            echo "✓ Up to date"
        end
    else
        echo "Could not determine version info"
    end
end

# Config helper
function codex_config --description 'Open Codex config in editor'
    set -l cfg (string replace -r '^~' $HOME $CODEX_CONFIG)
    if test -f $cfg
        $EDITOR $cfg
    else
        echo "Codex config not found at $CODEX_CONFIG"
        echo "Create it with: touch $CODEX_CONFIG"
    end
end

# Status helper
function codex_status --description 'Show Codex status and config'
    echo "Codex CLI Status"
    echo "================"
    echo ""
    echo "Version:  $(codex --version 2>/dev/null || echo 'not found')"
    echo "Location: $(which codex 2>/dev/null || echo 'not in PATH')"
    echo "Config:   $CODEX_CONFIG"
    echo "Profile:  $CODEX_PROFILE"
    echo "Sandbox:  $CODEX_SANDBOX"
    echo ""
    if test -f $CODEX_CONFIG
        echo "Config exists: ✓"
    else
        echo "Config exists: ✗ (touch $CODEX_CONFIG)"
    end
end
