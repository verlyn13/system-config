#!/usr/bin/env fish
# GAM7 — Google Workspace CLI (managed via chezmoi)
# Source: https://github.com/GAM-team/GAM
# Install: bash <(curl -s -S -L https://git.io/gam-install)
# Update:  bash <(curl -s -S -L https://git.io/gam-install) -l

# GAM installs to ~/bin/gam7/ by default
set -l _gam_dir ~/bin/gam7
if test -d $_gam_dir
    fish_add_path -a $_gam_dir
end

# Quick status helper
function gam_status --description 'Show GAM version and install location'
    if type -q gam
        echo "GAM location: "(which gam)
        gam version
    else
        echo "GAM not found."
        echo "Install: bash <(curl -s -S -L https://git.io/gam-install)"
    end
end

# Update helper
function gam_update --description 'Update GAM to the latest version'
    echo "Updating GAM..."
    bash <(curl -s -S -L https://git.io/gam-install) -l
end
