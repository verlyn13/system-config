#!/usr/bin/env fish
# MCP server token auto-load (managed via chezmoi)
# Exports API tokens needed by MCP servers at shell startup.
# Requires gopass; silently skips missing secrets.

# Note: GITHUB_TOKEN and CONTEXT7_API_KEY are loaded globally in 40-secrets.fish.tmpl.
# CLOUDFLARE_API_TOKEN is project-scoped — loaded via dicee/.envrc (direnv), not globally,
# because Cloudflare API calls can be metered. Run `dicee-cf` to load it manually if needed.

# === Functions ===

# Refresh Cloudflare token on demand (useful after token rotation)
function dicee-cf --description 'Refresh CLOUDFLARE_API_TOKEN from gopass'
    if not type -q gopass
        echo "dicee-cf: gopass not found" >&2
        return 1
    end
    set -l token (gopass show -o dicee/cloudflare/api-token 2>/dev/null)
    if test -z "$token"
        echo "dicee-cf: secret not found at dicee/cloudflare/api-token" >&2
        return 1
    end
    set -gx CLOUDFLARE_API_TOKEN $token
    echo "CLOUDFLARE_API_TOKEN refreshed"
end

# Show current MCP token export status
function mcp-token-status --description 'Show MCP API token export status'
    echo "=== MCP Token Status ==="
    for pair in \
        "CLOUDFLARE_API_TOKEN:dicee/cloudflare/api-token" \
        "CONTEXT7_API_KEY:dicee/context7/api-key" \
        "GITHUB_TOKEN:github/dev-tools-token"
        set -l var (string split ":" $pair)[1]
        set -l path (string split ":" $pair)[2]
        if set -q $var
            echo "  $var: set"
        else
            echo "  $var: NOT set  (gopass path: $path)"
        end
    end
end
