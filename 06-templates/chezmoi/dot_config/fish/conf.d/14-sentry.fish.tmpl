#!/usr/bin/env fish
# Sentry CLI Configuration (managed via chezmoi)
# Single source of truth for Sentry CLI commands and configuration
# Installation: npm install -g @sentry/cli
# Docs: https://docs.sentry.io/cli/

# Sentry CLI binary path (set if using local install)
if not set -q SENTRY_BIN
    # Default: use npm global installation
    set -gx SENTRY_BIN ~/.npm-global/bin/sentry-cli
end

# Authentication via environment variables
# Set these in your .envrc or environment:
# SENTRY_AUTH_TOKEN - Authentication token (recommended)
# SENTRY_ORG - Organization slug
# SENTRY_PROJECT - Project slug
# SENTRY_URL - Self-hosted Sentry URL (optional, defaults to sentry.io)

# How to fetch auth token from gopass
if not set -q SENTRY_AUTH_TOKEN_CMD
    set -gx SENTRY_AUTH_TOKEN_CMD "gopass show sentry/auth-token"
end

function __sentry_exec --description 'Execute Sentry CLI (prefer npm global install)'
    # Modern approach: use npm global installation at ~/.npm-global/bin/sentry-cli
    if test -x $SENTRY_BIN
        command $SENTRY_BIN $argv
        return $status
    end

    # Fallback: check PATH for 'sentry-cli'
    if type -q sentry-cli
        command sentry-cli $argv
        return $status
    end

    echo 'sentry-cli: CLI not found. Run: npm install -g @sentry/cli'
    return 127
end

function __sentry_resolve_auth_token --description 'resolve SENTRY_AUTH_TOKEN'
    if set -q SENTRY_AUTH_TOKEN
        echo $SENTRY_AUTH_TOKEN
        return 0
    end
    if type -q gopass
        set -l token (eval $SENTRY_AUTH_TOKEN_CMD 2>/dev/null)
        if test -n "$token"
            echo $token
            return 0
        end
    end
    return 1
end

function __sentry_run --description 'run Sentry CLI with auth handling'
    set -l args $argv

    # If SENTRY_AUTH_TOKEN not set, try to resolve from gopass
    if not set -q SENTRY_AUTH_TOKEN
        set -l token (__sentry_resolve_auth_token)
        if test -n "$token"
            env SENTRY_AUTH_TOKEN="$token" __sentry_exec $args
            return $status
        end
    end

    # Run with existing environment
    __sentry_exec $args
end

# Public commands (simple, documented)
function sentry --description 'Sentry CLI'
    __sentry_run $argv
end

function sentry-cli --description 'Sentry CLI (explicit)'
    __sentry_run $argv
end

# Common Sentry CLI shortcuts
function sentry-upload --description 'Upload source maps to Sentry'
    __sentry_run sourcemaps upload $argv
end

function sentry-releases --description 'Manage Sentry releases'
    __sentry_run releases $argv
end

function sentry-info --description 'Show Sentry configuration info'
    __sentry_run info $argv
end

function sentry-login --description 'Authenticate with Sentry'
    __sentry_run login $argv
end

# Version check helper (run manually: sentry_check_updates)
function sentry_check_updates --description 'Check for Sentry CLI updates'
    set -l current (sentry-cli --version 2>/dev/null | grep -o '[0-9]\+\.[0-9]\+\.[0-9]\+' | head -1)
    set -l latest (npm view @sentry/cli version 2>/dev/null)

    if test -n "$current" -a -n "$latest"
        echo "Current: v$current"
        echo "Latest:  v$latest"
        if test "$current" != "$latest"
            echo ""
            echo "Update available! Run: npm update -g @sentry/cli"
        else
            echo "✓ Up to date"
        end
    else
        echo "Could not determine version info"
    end
end

# Status check helper
function sentry_status --description 'Show Sentry CLI installation status'
    echo "=== Sentry CLI Status ==="

    # Check if binary exists
    if type -q sentry-cli
        echo "✓ Binary found: "(which sentry-cli)
        set -l version (sentry-cli --version 2>/dev/null | grep -o '[0-9]\+\.[0-9]\+\.[0-9]\+' | head -1)
        if test -n "$version"
            echo "✓ Version: v$version"
        end
    else
        echo "✗ Binary not found"
    end

    # Check authentication
    if set -q SENTRY_AUTH_TOKEN
        echo "✓ SENTRY_AUTH_TOKEN: set"
    else
        set -l token (__sentry_resolve_auth_token 2>/dev/null)
        if test -n "$token"
            echo "✓ Auth token: available via gopass"
        else
            echo "⚠ Auth token: not set (required for most operations)"
        end
    end

    # Check org/project config
    if set -q SENTRY_ORG
        echo "✓ SENTRY_ORG: $SENTRY_ORG"
    else
        echo "⚠ SENTRY_ORG: not set"
    end

    if set -q SENTRY_PROJECT
        echo "✓ SENTRY_PROJECT: $SENTRY_PROJECT"
    else
        echo "⚠ SENTRY_PROJECT: not set"
    end

    if set -q SENTRY_URL
        echo "✓ SENTRY_URL: $SENTRY_URL"
    else
        echo "  SENTRY_URL: not set (using default: sentry.io)"
    end

    echo ""
    echo "Run 'sentry-cli info' for detailed configuration"
end
