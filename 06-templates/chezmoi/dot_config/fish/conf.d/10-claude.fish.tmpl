#!/usr/bin/env fish
# Claude Code CLI Configuration (managed via chezmoi)
# Installation: curl -fsSL https://claude.ai/install.sh | bash
# Docs: https://docs.anthropic.com/en/docs/claude-code/overview

# === Environment ===
# Native installer location (replaces npm-global path)
if not set -q CLAUDE_BIN
    set -gx CLAUDE_BIN ~/.local/bin/claude
end
set -gx CLAUDE_CONFIG_DIR ~/.claude

# Disable telemetry (also configurable in settings.json)
set -gx DISABLE_TELEMETRY 1
set -gx DISABLE_ERROR_REPORTING 1

# Performance tuning (adjust per machine)
set -gx MAX_THINKING_TOKENS 32000
set -gx BASH_DEFAULT_TIMEOUT_MS 300000
set -gx BASH_MAX_TIMEOUT_MS 600000
set -gx MCP_TIMEOUT 60000
set -gx MCP_TOOL_TIMEOUT 120000

# === Abbreviations ===
abbr -a cc 'claude'
abbr -a ccp 'claude -p'
abbr -a ccr 'claude --resume'
abbr -a ccc 'claude --continue'
abbr -a ccd 'claude --add-dir'

# === Functions ===

# Initialize Claude Code project structure
function claude-init -d "Initialize Claude Code project in current directory"
    set -l project_dir (pwd)
    set -l project_name (basename $project_dir)

    echo "Initializing Claude Code project: $project_name"

    mkdir -p .claude/commands .claude/agents

    # Create settings.json if not exists
    if not test -f .claude/settings.json
        echo '{
  "permissions": {
    "allow": [],
    "ask": [],
    "deny": ["Read(./.env)", "Read(./.env.*)"]
  }
}' > .claude/settings.json
        echo "  Created .claude/settings.json"
    end

    # Create CLAUDE.md if not exists
    if not test -f CLAUDE.md
        echo "# Project: $project_name

## Overview
<!-- Project description -->

## Tech Stack
<!-- Languages, frameworks, tools -->

## Commands
<!-- Common commands: build, test, lint -->
" > CLAUDE.md
        echo "  Created CLAUDE.md"
    end

    # Update .gitignore
    if test -f .gitignore
        if not grep -q "settings.local.json" .gitignore
            echo "
# Claude Code
.claude/settings.local.json
.claude/activity.log" >> .gitignore
            echo "  Updated .gitignore"
        end
    end

    echo "Done!"
end

# Quick code review with Claude
function claude-review -d "Review staged changes or specified files"
    set -l target $argv
    if test -z "$target"
        set target (git diff --staged --name-only | string join " ")
    end

    if test -z "$target"
        echo "No staged changes and no files specified"
        return 1
    end

    claude -p "Review these changes for bugs, security issues, and improvements: $target"
end

# Project detection on directory change
function __claude_project_check --on-variable PWD
    if test -f CLAUDE.md -o -d .claude
        set_color cyan
        echo "󰚩 Claude Code project"
        set_color normal
    end
end

# Version check and update helper
function claude_check_updates -d "Check for Claude CLI updates and update if available"
    set -l current (claude --version 2>/dev/null | grep -o '[0-9]\+\.[0-9]\+\.[0-9]\+' | head -1)

    if test -n "$current"
        echo "Current: v$current"
        echo ""
        echo "Checking for updates..."
        claude update
    else
        echo "Claude CLI not found. Install with: curl -fsSL https://claude.ai/install.sh | bash"
    end
end

# Provide 'claude' if PATH doesn't include ~/.local/bin but CLAUDE_BIN exists
if not type -q claude
    if test -x $CLAUDE_BIN
        function claude --description 'Claude Code CLI'
            $CLAUDE_BIN $argv
        end
    end
end
