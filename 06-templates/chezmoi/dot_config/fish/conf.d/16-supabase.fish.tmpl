#!/usr/bin/env fish
# Supabase CLI Configuration (managed via chezmoi)
# Single source of truth for Supabase CLI commands and configuration
# Installation: brew install supabase/tap/supabase (or npm install -g supabase)
# Docs: https://supabase.com/docs/guides/cli

# Supabase CLI binary path (set if using specific install)
if not set -q SUPABASE_BIN
    # Default: use Homebrew or npm global installation
    set -gx SUPABASE_BIN (which supabase 2>/dev/null || echo ~/.npm-global/bin/supabase)
end

# Authentication and project configuration
# Set in your .envrc or environment:
# SUPABASE_ACCESS_TOKEN - Personal access token for CLI
# SUPABASE_PROJECT_ID - Project ID (for CI/CD)
# SUPABASE_DB_PASSWORD - Database password (for remote connections)

# How to fetch access token from gopass
if not set -q SUPABASE_ACCESS_TOKEN_CMD
    set -gx SUPABASE_ACCESS_TOKEN_CMD "gopass show supabase/access-token"
end

function __supabase_exec --description 'Execute Supabase CLI'
    # Use Homebrew installation first
    if test -x /opt/homebrew/bin/supabase
        command /opt/homebrew/bin/supabase $argv
        return $status
    end

    # Fallback to npm global
    if test -x $SUPABASE_BIN
        command $SUPABASE_BIN $argv
        return $status
    end

    # Last resort: check PATH
    if type -q supabase
        command supabase $argv
        return $status
    end

    echo 'supabase: CLI not found. Install with: brew install supabase/tap/supabase'
    return 127
end

function __supabase_resolve_token --description 'resolve SUPABASE_ACCESS_TOKEN'
    if set -q SUPABASE_ACCESS_TOKEN
        echo $SUPABASE_ACCESS_TOKEN
        return 0
    end
    if type -q gopass
        set -l token (eval $SUPABASE_ACCESS_TOKEN_CMD 2>/dev/null)
        if test -n "$token"
            echo $token
            return 0
        end
    end
    return 1
end

function __supabase_run --description 'run Supabase CLI with auth handling'
    set -l args $argv

    # If SUPABASE_ACCESS_TOKEN not set, try to resolve from gopass
    if not set -q SUPABASE_ACCESS_TOKEN
        set -l token (__supabase_resolve_token)
        if test -n "$token"
            env SUPABASE_ACCESS_TOKEN="$token" __supabase_exec $args
            return $status
        end
    end

    # Run with existing environment
    __supabase_exec $args
end

# Public commands (simple, documented)
function supabase --description 'Supabase CLI'
    __supabase_run $argv
end

