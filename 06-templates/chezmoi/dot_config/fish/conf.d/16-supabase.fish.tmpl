    __supabase_run logs $argv
end

function sb-types --description 'Generate TypeScript types for project'
    set -l output_path (test -n "$argv[1]"; and echo "$argv[1]"; or echo "types/supabase.ts")
    echo "Generating TypeScript types to: $output_path"
    __supabase_run gen types typescript --local > $output_path
    echo "✓ Types generated"
end

# Version check helper (run manually: supabase_check_updates)
function supabase_check_updates --description 'Check for Supabase CLI updates'
    set -l current (supabase --version 2>/dev/null | grep -o '[0-9]\+\.[0-9]\+\.[0-9]\+' | head -1)

    # Check brew for latest version
    set -l latest (brew info supabase/tap/supabase 2>/dev/null | grep -o 'stable [0-9]\+\.[0-9]\+\.[0-9]\+' | cut -d' ' -f2)

    # Fallback to npm if brew check fails
    if test -z "$latest"
        set latest (npm view supabase version 2>/dev/null)
    end

    if test -n "$current" -a -n "$latest"
        echo "Current: v$current"
        echo "Latest:  v$latest"
        if test "$current" != "$latest"
            echo ""
            echo "Update available! Run:"
            echo "  brew upgrade supabase/tap/supabase"
            echo "  # or"
            echo "  npm update -g supabase"
        else
            echo "✓ Up to date"
        end
    else
        echo "Could not determine version info"
    end
end

# Status check helper
function supabase_status --description 'Show Supabase CLI installation status'
    echo "=== Supabase CLI Status ==="

    # Check if binary exists
    if type -q supabase
        echo "✓ Binary found: "(which supabase)
        set -l version (supabase --version 2>/dev/null | grep -o '[0-9]\+\.[0-9]\+\.[0-9]\+' | head -1)
        if test -n "$version"
            echo "✓ Version: v$version"
        end
    else
        echo "✗ Binary not found"
        return 1
    end

    # Check Docker
    if type -q docker
        if docker ps >/dev/null 2>&1
            echo "✓ Docker: running"
        else
            echo "⚠ Docker: not running (required for local development)"
        end
    else
        echo "✗ Docker: not installed (required for local development)"
    end

    # Check authentication
    if set -q SUPABASE_ACCESS_TOKEN
        echo "✓ SUPABASE_ACCESS_TOKEN: set"
    else
        set -l token (__supabase_resolve_token 2>/dev/null)
        if test -n "$token"
            echo "✓ Access token: available via gopass"
        else
            echo "⚠ Access token: not set (optional, required for remote operations)"
        end
    end

    # Check for local project
    if test -f supabase/config.toml
        echo "✓ Local project initialized (supabase/config.toml exists)"

        # Check if services are running
        set -l status_output (supabase status 2>&1)
        if test $status -eq 0
            echo "✓ Local services: running"
        else
            echo "⚠ Local services: stopped (run: supabase start)"
        end
    else
        echo "⚠ Not in a Supabase project directory"
        echo "  Run 'supabase init' to initialize"
    end

    # Check project link
    if test -f .git/config
        set -l linked_project (supabase status 2>/dev/null | grep "project id" | cut -d':' -f2 | tr -d ' ')
        if test -n "$linked_project"
            echo "✓ Linked to project: $linked_project"
        end
    end

    echo ""
    echo "Run 'supabase status' for service details"
    echo "Run 'supabase --help' for available commands"
end

# Quick project info
function supabase_info --description 'Show current project information'
    if not test -f supabase/config.toml
        echo "Not in a Supabase project directory"
        return 1
    end

    echo "=== Supabase Project Info ==="

    # Get project ID if linked
    set -l project_id (grep "project_id" supabase/.branches/_current_branch 2>/dev/null | cut -d'"' -f2)
    if test -n "$project_id"
        echo "Project ID: $project_id"
    end

    # Show local services status
    echo ""
    supabase status
end
