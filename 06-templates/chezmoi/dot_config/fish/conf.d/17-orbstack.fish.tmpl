#!/usr/bin/env fish
# OrbStack Configuration (managed via chezmoi)
# OrbStack is a fast, lightweight replacement for Docker Desktop
# Installation: brew install --cask orbstack
# Docs: https://docs.orbstack.dev/
#
# NOTE: OrbStack automatically installs docker, docker-compose, orb, and orbctl
# to /usr/local/bin and /opt/homebrew/bin. No PATH manipulation needed.
# This config only provides convenience aliases and helpers.

# Set environment variables for reference
if not set -q ORBSTACK_APP
    set -gx ORBSTACK_APP /Applications/OrbStack.app
end

# Load OrbStack Fish completions if available
if test -f "$ORBSTACK_APP/Contents/Resources/completions/fish/orbctl.fish"
    source "$ORBSTACK_APP/Contents/Resources/completions/fish/orbctl.fish"
end

# Convenience aliases for OrbStack management
# Note: These use the 'orb' command which is already in PATH via Homebrew/OrbStack

function orbstart --description 'Start OrbStack'
    if type -q orb
        orb start $argv
    else
        echo "orb command not found. Install OrbStack: brew install --cask orbstack"
        return 127
    end
end

function orbstop --description 'Stop OrbStack'
    if type -q orb
        orb stop $argv
    else
        echo "orb command not found. Install OrbStack: brew install --cask orbstack"
        return 127
    end
end

function orbrestart --description 'Restart OrbStack'
    if type -q orb
        orb restart $argv
    else
        echo "orb command not found. Install OrbStack: brew install --cask orbstack"
        return 127
    end
end

function orbstatus --description 'Show OrbStack running status'
    if type -q orb
        orb status $argv
    else
        echo "orb command not found. Install OrbStack: brew install --cask orbstack"
        return 127
    end
end

function orbinfo --description 'Show OrbStack system information'
    if type -q orb
        orb info $argv
    else
        echo "orb command not found. Install OrbStack: brew install --cask orbstack"
        return 127
    end
end

function orbopen --description 'Open OrbStack application'
    if test -d $ORBSTACK_APP
        open $ORBSTACK_APP
    else
        echo "OrbStack app not found at $ORBSTACK_APP"
        echo "Install: brew install --cask orbstack"
        return 127
    end
end

# Docker convenience aliases (use existing docker commands, just provide shortcuts)
function dps --description 'Docker ps - List running containers'
    if type -q docker
        docker ps $argv
    else
        echo "docker command not found. Install OrbStack or Docker Desktop."
        return 127
    end
end

function dpsa --description 'Docker ps -a - List all containers'
    if type -q docker
        docker ps -a $argv
    else
        echo "docker command not found. Install OrbStack or Docker Desktop."
        return 127
    end
end

function dimages --description 'Docker images - List images'
    if type -q docker
        docker images $argv
    else
        echo "docker command not found. Install OrbStack or Docker Desktop."
        return 127
    end
end

function dclean --description 'Docker system prune - Clean up unused resources'
    if type -q docker
        echo "This will remove:"
        echo "  - All stopped containers"
        echo "  - All networks not used by at least one container"
        echo "  - All dangling images"
        echo "  - All build cache"
        echo ""
        read -P "Continue? [y/N] " -n 1 -r
        echo
        if test "$REPLY" = "y" -o "$REPLY" = "Y"
            docker system prune $argv
        else
            echo "Cancelled"
        end
    else
        echo "docker command not found. Install OrbStack or Docker Desktop."
        return 127
    end
end

# Version check helper
function orbstack_check_updates --description 'Check for OrbStack updates'
    if type -q brew
        echo "Checking for OrbStack updates via Homebrew..."
        brew info --cask orbstack | grep -E "orbstack:|Not installed|From:"
        echo ""
        echo "To update: brew upgrade --cask orbstack"
    else
        echo "Homebrew not found. Install updates manually from https://orbstack.dev"
    end
end

# Comprehensive status helper for troubleshooting
function orbstack_status --description 'Show OrbStack installation and running status'
    echo "OrbStack Status"
    echo "==============="
    echo ""

    # Check if OrbStack app is installed
    if test -d $ORBSTACK_APP
        echo "✓ Application installed: $ORBSTACK_APP"

        # Get version if orb command works
        if type -q orb
            set -l orb_version (orb version 2>/dev/null | head -1)
            if test -n "$orb_version"
                echo "✓ Version: $orb_version"
            end
        end
    else
        echo "✗ Application not found at: $ORBSTACK_APP"
        echo "  Install: brew install --cask orbstack"
    end

    echo ""

    # Check orb CLI
    if type -q orb
        echo "✓ orb CLI available: $(which orb)"

        # Try to get status (will fail if not running)
        set -l status_output (orb status 2>/dev/null)
        if test $status = 0 -a -n "$status_output"
            echo "✓ OrbStack is running"
            echo ""
            echo "Current Status:"
            echo "$status_output"
        else
            echo "⚠ OrbStack not running (use 'orbstart' to start)"
        end
    else
        echo "✗ orb CLI not in PATH"
        echo "  Expected at: /opt/homebrew/bin/orb or /usr/local/bin/orb"
    end

    echo ""

    # Check orbctl CLI
    if type -q orbctl
        echo "✓ orbctl CLI available: $(which orbctl)"
    else
        echo "✗ orbctl CLI not in PATH"
    end

    echo ""

    # Check Docker CLI
    if type -q docker
        echo "✓ docker CLI available: $(which docker)"
        set -l docker_version (docker --version 2>/dev/null)
        if test -n "$docker_version"
            echo "  $docker_version"
        end

        # Check if Docker daemon is accessible
        if docker ps >/dev/null 2>&1
            echo "✓ Docker daemon is running and accessible"
        else
            echo "⚠ Docker daemon not accessible (start OrbStack first)"
        end
    else
        echo "✗ docker CLI not in PATH"
    end

    echo ""

    # Check docker-compose CLI
    if type -q docker-compose
        echo "✓ docker-compose CLI available: $(which docker-compose)"
        set -l compose_version (docker-compose --version 2>/dev/null)
        if test -n "$compose_version"
            echo "  $compose_version"
        end
    else
        echo "✗ docker-compose CLI not in PATH"
    end

    echo ""
    echo "Available commands:"
    echo "  orb, orbctl       - OrbStack management"
    echo "  docker, docker-compose - Docker commands"
    echo "  orbstart, orbstop - Start/stop OrbStack"
    echo "  orbstatus, orbinfo - Status and info"
    echo "  dps, dpsa, dimages, dclean - Docker shortcuts"
end
