{{- /* Fish shell main configuration (chezmoi-managed) */ -}}
{{- /* Pro-level modern setup with Fisher, Tmux, and beautiful prompts */ -}}
# Fish Shell Configuration ({{ .chezmoi.hostname }})
# Last updated: {{ now | date "2006-01-02" }}
# Managed by: chezmoi
#
# IMPORTANT: This config is designed to EXTEND existing conf.d files, not replace them
# conf.d files are loaded AFTER this config in alphabetical order

# ============================================================================
# SECURITY & ENVIRONMENT SETUP (Must be first)
# ============================================================================

# MISE trusted config paths (security-critical, loaded before anything else)
set -gx MISE_TRUSTED_CONFIG_PATHS "~/Development/**" "~/workspace/**"
set -gx MISE_EXPERIMENTAL 1

# ============================================================================
# INTERACTIVE SHELL SETUP
# ============================================================================

if status is-interactive
    # ------------------------------------------------------------------------
    # Fisher Plugin Manager Check
    # ------------------------------------------------------------------------
    # Fisher is our modern plugin manager for Fish
    # Only show reminder if not installed (non-intrusive)

    if not functions -q fisher
        # Only show once per day using a flag file
        set -l fisher_reminder_file ~/.config/fish/.fisher_reminder
        if not test -f $fisher_reminder_file; or test (find $fisher_reminder_file -mtime +1d 2>/dev/null)
            echo (set_color yellow)"⚠️  Fisher plugin manager not found."(set_color normal)
            echo "   Install: curl -sL https://raw.githubusercontent.com/jorgebucaran/fisher/main/functions/fisher.fish | source && fisher install jorgebucaran/fisher"
            touch $fisher_reminder_file
        end
    end

    # ------------------------------------------------------------------------
    # Tmux Auto-Start Configuration (Option B: Pure Tmux, no iTerm2 integration)
    # ------------------------------------------------------------------------
    # The tmux.fish plugin (budimanjojo/tmux.fish) handles auto-start
    # These variables must be set BEFORE the plugin loads (conf.d runs after config.fish)

    {{- if not (.headless | default false) }}
    # Tmux configuration for tmux.fish plugin
    # Auto-start is DISABLED - launch tmux manually when needed
    # To enable auto-start: set -g fish_tmux_autostart true
    set -g fish_tmux_autostart false       # Manual tmux launch (default behavior)
    set -g fish_tmux_iterm2 false          # Option B: Pure Tmux workflow
    set -g fish_tmux_unicode true          # Enable Unicode/Icon support

    if test -f ~/.tmux.conf
        set -g fish_tmux_config ~/.tmux.conf
    end
    {{- else }}
    # Headless mode: disable tmux auto-start
    set -g fish_tmux_autostart false
    {{- end }}

    # ------------------------------------------------------------------------
    # Greeting Configuration
    # ------------------------------------------------------------------------
    # Disable default fish greeting (we have a beautiful prompt instead)
    set -g fish_greeting ""

    # ------------------------------------------------------------------------
    # Editor Configuration
    # ------------------------------------------------------------------------
    {{- if eq (.editor | default "code") "code" }}
    set -gx EDITOR "code --wait"
    set -gx VISUAL "code --wait"
    {{- else if eq (.editor | default "code") "vim" }}
    set -gx EDITOR vim
    set -gx VISUAL vim
    {{- else }}
    set -gx EDITOR nano
    set -gx VISUAL nano
    {{- end }}

    # ------------------------------------------------------------------------
    # TERM Configuration - CRITICAL: Do NOT override inside tmux!
    # ------------------------------------------------------------------------
    # Only set TERM if not already inside tmux
    # Tmux sets its own TERM and we must not override it
    if not set -q TMUX
        # Only set if terminal doesn't already have good color support
        if test "$TERM" = "xterm"; or test "$TERM" = "screen"
            set -gx TERM xterm-256color
        end
    end

    # ------------------------------------------------------------------------
    # FZF Configuration (if fzf.fish plugin is installed)
    # ------------------------------------------------------------------------
    # These variables customize the fzf.fish plugin behavior
    # Plugin: PatrickF1/fzf.fish

    # Use fd instead of find (faster, respects .gitignore)
    if type -q fd
        set -gx FZF_DEFAULT_COMMAND 'fd --type f --hidden --follow --exclude .git'
        set -gx FZF_CTRL_T_COMMAND "$FZF_DEFAULT_COMMAND"
    end

    # FZF color scheme (Catppuccin Mocha) - only if fzf is installed
    if type -q fzf
        set -gx FZF_DEFAULT_OPTS "\
            --height 40% \
            --layout=reverse \
            --border \
            --inline-info \
            --color=bg+:#313244,bg:#1e1e2e,spinner:#f5e0dc,hl:#f38ba8 \
            --color=fg:#cdd6f4,header:#f38ba8,info:#cba6f7,pointer:#f5e0dc \
            --color=marker:#f5e0dc,fg+:#cdd6f4,prompt:#cba6f7,hl+:#f38ba8"
    end

    # ------------------------------------------------------------------------
    # Aliases (Pro-level safety and productivity)
    # ------------------------------------------------------------------------
    # IMPORTANT: Only set aliases if commands exist to avoid breaking things

    # Safety aliases (interactive confirmations)
    alias rm 'rm -i'
    alias cp 'cp -i'
    alias mv 'mv -i'

    # Enhanced ls (use eza if available, otherwise fall back to standard ls)
    if type -q eza
        alias ls 'eza --icons --group-directories-first'
        alias ll 'eza -lah --icons --group-directories-first --git'
        alias la 'eza -a --icons --group-directories-first'
        alias lt 'eza -T --icons --group-directories-first'
        alias l 'eza -lh --icons --group-directories-first'
    else if type -q gls
        # GNU ls (from coreutils)
        alias ls 'gls --color=auto --group-directories-first'
        alias ll 'gls -lah --color=auto --group-directories-first'
        alias la 'gls -A --color=auto --group-directories-first'
    else
        # macOS/BSD ls
        alias ls 'ls -G'
        alias ll 'ls -lah -G'
        alias la 'ls -A -G'
    end

    # Better cat (use bat if available)
    if type -q bat
        alias cat 'bat --style=auto'
    end

    # Directory navigation shortcuts
    alias .. 'cd ..'
    alias ... 'cd ../..'
    alias .... 'cd ../../..'
    alias ..... 'cd ../../../..'

    # Git shortcuts (only if git is installed)
    if type -q git
        alias g 'git'
        alias gs 'git status'
        alias ga 'git add'
        alias gc 'git commit'
        alias gp 'git push'
        alias gl 'git pull'
        alias gd 'git diff'
        alias gco 'git checkout'
        alias gb 'git branch'
        alias glog 'git log --oneline --graph --decorate'
    end

    # Chezmoi shortcuts (only if chezmoi is installed)
    if type -q chezmoi
        alias cz 'chezmoi'
        alias cza 'chezmoi apply'
        alias czd 'chezmoi diff'
        alias cze 'chezmoi edit'
        alias czs 'chezmoi status'
    end

    # Tmux shortcuts (only if tmux is installed)
    if type -q tmux
        alias ta 'tmux attach'
        alias tat 'tmux attach -t'
        alias tns 'tmux new-session -s'
        alias tls 'tmux list-sessions'
        alias tkill 'tmux kill-session -t'
    end

    # System shortcuts
    alias c 'clear'
    alias h 'history'
    alias j 'jobs'

    # Network shortcuts (only if lsof is available)
    if type -q lsof
        alias ports 'lsof -i -P -n | grep LISTEN'
    end

    # macOS-specific (only on Darwin)
    {{- if eq .chezmoi.os "darwin" }}
    alias flushdns 'sudo dscacheutil -flushcache; sudo killall -HUP mDNSResponder'
    alias showfiles 'defaults write com.apple.finder AppleShowAllFiles YES; killall Finder'
    alias hidefiles 'defaults write com.apple.finder AppleShowAllFiles NO; killall Finder'
    {{- end }}

    # ------------------------------------------------------------------------
    # Custom Functions
    # ------------------------------------------------------------------------

    # Quick directory creation and navigation
    function mkcd --description "Create directory and cd into it"
        if test (count $argv) -eq 0
            echo "Usage: mkcd <directory>"
            return 1
        end
        mkdir -p $argv[1] && cd $argv[1]
    end

    # Extract archives (smart extractor)
    function extract --description "Extract various archive formats"
        if test (count $argv) -eq 0
            echo "Usage: extract <archive-file>"
            return 1
        end

        if not test -f $argv[1]
            echo "Error: '$argv[1]' is not a valid file"
            return 1
        end

        switch $argv[1]
            case '*.tar.bz2'
                tar xjf $argv[1]
            case '*.tar.gz'
                tar xzf $argv[1]
            case '*.bz2'
                bunzip2 $argv[1]
            case '*.rar'
                if type -q unrar
                    unrar x $argv[1]
                else
                    echo "Error: unrar not installed"
                    return 1
                end
            case '*.gz'
                gunzip $argv[1]
            case '*.tar'
                tar xf $argv[1]
            case '*.tbz2'
                tar xjf $argv[1]
            case '*.tgz'
                tar xzf $argv[1]
            case '*.zip'
                unzip $argv[1]
            case '*.Z'
                uncompress $argv[1]
            case '*.7z'
                if type -q 7z
                    7z x $argv[1]
                else
                    echo "Error: 7z not installed"
                    return 1
                end
            case '*'
                echo "Error: '$argv[1]' cannot be extracted (unsupported format)"
                return 1
        end
    end

    # Find and cd to directory (requires find)
    function fcd --description "Find directory and cd into it"
        if test (count $argv) -eq 0
            echo "Usage: fcd <search-pattern>"
            return 1
        end

        set -l found_dir (find . -type d -name "*$argv[1]*" 2>/dev/null | head -1)

        if test -n "$found_dir"
            cd $found_dir
        else
            echo "No directory found matching: $argv[1]"
            return 1
        end
    end

    # Get weather (requires curl)
    function weather --description "Get weather for a location"
        if type -q curl
            if test (count $argv) -eq 0
                curl -s "wttr.in?format=3"
            else
                curl -s "wttr.in/$argv[1]?format=3"
            end
        else
            echo "Error: curl not installed"
            return 1
        end
    end

    # Quick note taking
    function note --description "Quick note taking to ~/notes"
        set -l note_dir ~/notes
        set -l note_file $note_dir/(date +%Y-%m-%d).md

        mkdir -p $note_dir

        if test (count $argv) -gt 0
            # Append note with timestamp
            echo "- "(date +%H:%M)" $argv" >> $note_file
            echo "Note added to $note_file"
        else
            # Open today's note in editor
            if test -n "$EDITOR"
                $EDITOR $note_file
            else
                echo "Error: EDITOR not set"
                return 1
            end
        end
    end

end

# ============================================================================
# CONFIGURATION LOADING
# ============================================================================

# Additional configurations are loaded from conf.d/ in alphabetical order:
# - 00-homebrew.fish    : Homebrew environment (CRITICAL for PATH)
# - 01-mise.fish        : mise version manager (CRITICAL for PATH)
# - 02-direnv.fish      : direnv integration
# - 03-starship.fish    : Starship prompt
# - 04-paths.fish       : PATH management (CRITICAL)
# - 05-keybindings.fish : Custom key bindings
# - 06-tmux.fish        : Tmux integration helpers (NEW)
# - 10-19-*.fish        : Tool-specific configurations
# - 20+                 : Additional configurations (secrets, functions, etc.)

# These files are automatically loaded by Fish - DO NOT source them here

# ============================================================================
# PERFORMANCE OPTIMIZATION
# ============================================================================

# Disable default Vi mode indicator (we use prompt for this)
function fish_mode_prompt; end

# ============================================================================
# MACHINE-SPECIFIC OVERRIDES
# ============================================================================

# Load machine-specific configuration if it exists (not managed by chezmoi)
# This allows local customization without affecting the managed config
if test -f ~/.config/fish/config.local.fish
    source ~/.config/fish/config.local.fish
end
