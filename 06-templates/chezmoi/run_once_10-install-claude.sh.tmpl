#!/usr/bin/env bash
set -euo pipefail

echo "[chezmoi] Installing Claude Code CLI via npm"

have() { command -v "$1" >/dev/null 2>&1; }

# Check if already installed
if have claude; then
  current_version=$(claude --version 2>/dev/null | grep -o '[0-9]\+\.[0-9]\+\.[0-9]\+' | head -1 || echo "unknown")
  echo "[chezmoi] Claude CLI already installed (v${current_version})"

  # Check for updates
  if have npm; then
    latest_version=$(npm view @anthropic-ai/claude-code version 2>/dev/null || echo "unknown")
    if [[ "$current_version" != "$latest_version" && "$latest_version" != "unknown" ]]; then
      echo "[chezmoi] Update available: v${current_version} → v${latest_version}"
      echo "[chezmoi] Run: npm update -g @anthropic-ai/claude-code"
    fi
  fi
  exit 0
fi

# Ensure npm is available
if ! have npm; then
  echo "[chezmoi] ERROR: npm not found. Install Node.js/npm first."
  echo "[chezmoi] Run: brew install node"
  exit 1
fi

# Install Claude Code CLI from npm
echo "[chezmoi] Installing @anthropic-ai/claude-code globally..."
npm install -g @anthropic-ai/claude-code

if have claude; then
  version=$(claude --version 2>/dev/null | grep -o '[0-9]\+\.[0-9]\+\.[0-9]\+' | head -1)
  echo "[chezmoi] ✓ Claude Code CLI v${version} installed"
  echo "[chezmoi] Location: $(which claude)"
else
  echo "[chezmoi] WARNING: Installation completed but 'claude' command not found in PATH"
  echo "[chezmoi] Check ~/.npm-global/bin is in your PATH"
fi
