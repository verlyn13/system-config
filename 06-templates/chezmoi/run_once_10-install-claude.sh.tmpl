#!/usr/bin/env bash
set -euo pipefail

echo "[chezmoi] Installing Claude Code CLI via native installer"

have() { command -v "$1" >/dev/null 2>&1; }

# Native install location
NATIVE_BIN="$HOME/.local/bin/claude"
NATIVE_DATA="$HOME/.local/share/claude"

# Check if already installed via native installer
if [[ -x "$NATIVE_BIN" ]]; then
  current_version=$("$NATIVE_BIN" --version 2>/dev/null | grep -o '[0-9]\+\.[0-9]\+\.[0-9]\+' | head -1 || echo "unknown")
  echo "[chezmoi] Claude CLI already installed (v${current_version}) at $NATIVE_BIN"

  # Check for updates using claude's built-in update
  echo "[chezmoi] To update, run: claude update"
  exit 0
fi

# Remove old npm version if it exists
if have npm; then
  if npm list -g @anthropic-ai/claude-code >/dev/null 2>&1; then
    echo "[chezmoi] Removing old npm installation..."
    npm uninstall -g @anthropic-ai/claude-code || true
  fi
fi

# Ensure ~/.local/bin exists and is in PATH
mkdir -p "$HOME/.local/bin"

# Install via native installer
echo "[chezmoi] Running native installer..."
curl -fsSL https://claude.ai/install.sh | bash

if [[ -x "$NATIVE_BIN" ]]; then
  version=$("$NATIVE_BIN" --version 2>/dev/null | grep -o '[0-9]\+\.[0-9]\+\.[0-9]\+' | head -1)
  echo "[chezmoi] ✓ Claude Code CLI v${version} installed"
  echo "[chezmoi] Location: $NATIVE_BIN"
  echo "[chezmoi] Data: $NATIVE_DATA"
else
  echo "[chezmoi] WARNING: Installation completed but 'claude' not found at $NATIVE_BIN"
  echo "[chezmoi] Ensure ~/.local/bin is in your PATH"
fi
