apiVersion: devops.v1
project:
  id: github:org/project
  name: project
  org: org
  tier: dev
  kind: app
  owners: ["me@example.com"]
runtime:
  language: node
repo:
  url: "git@github.com:org/project.git"
  defaultBranch: main
quality:
  minCoverage: 0.8
observability:
  slo:
    ciSuccessRate: ">=0.95"
    p95LocalBuildSec: "<=120"
dependencies:
  packageManagers: [npm]
security:
  secretRefs:
    - secret://gopass/org/project/ci-token
dashboard:
  panels: ["buildHealth","coverage","deps","repoStatus","obsLatency"]
