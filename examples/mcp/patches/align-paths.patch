 const alias: Record<string,string> = { repo: 'git', deps: 'mise' };
 const canonical = new Set(['git','mise','sbom','build','manifest']);
@@
 export async function runExternalObserver(projectPath: string, projectId: string, obs: string) {
   const canonicalObs = alias[obs] || obs;
   if (!canonical.has(canonicalObs)) throw new Error('observer_invalid');
   const script = mapToScript(canonicalObs);
   const out = await safeExec(script, [projectPath, projectId]);
   const dir = path.join(Observers.out_dir, encode(projectId));
   await fs.promises.mkdir(dir, { recursive: true });
   // canonicalize line
   let obj = JSON.parse(out.trim());
   if (obj.observer === 'repo') obj.observer = 'git';
   if (obj.observer === 'deps') obj.observer = 'mise';
   const line = JSON.stringify(obj);
   await append(path.join(dir, canonicalObs + '.ndjson'), line + '\n');
   await append(path.join(dir, 'observations.ndjson'), line + '\n');
   await fs.promises.writeFile(path.join(dir, 'latest.json'), JSON.stringify(obj, null, 2));
   return { ok: true, file: path.join(dir, canonicalObs + '.ndjson') };
 }

