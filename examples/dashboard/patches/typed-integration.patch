 const express = require('express');
 const fetch = (...args) => import('node-fetch').then(({default: fetch}) => fetch(...args));
 const app = express();
 app.use(express.json());
 const BRIDGE = process.env.OBS_BRIDGE_URL || 'http://127.0.0.1:7171';

 // Discovery proxy to bridge
 app.get('/api/discovery/schemas', async (req, res) => {
   const r = await fetch(`${BRIDGE}/api/discovery/schemas`, { headers: { 'If-None-Match': req.headers['if-none-match'] || '' } });
   if (r.status === 304) return res.status(304).end();
   const etag = r.headers.get('etag');
   const body = await r.text();
   res.status(r.status);
   if (etag) res.set('ETag', etag);
   res.type('application/json').send(body);
 });

 app.get('/api/discovery/registry', async (req, res) => {
   const r = await fetch(`${BRIDGE}/api/discovery/registry`);
   const body = await r.text();
   res.status(r.status).type('application/json').send(body);
 });

 // Existing routes remain...

 module.exports = app;

