 +import React, { createContext, useContext, useEffect, useMemo, useState } from 'react';
 +import { loadSchemas, buildValidators } from '../lib/contracts';
 +
 +const Ctx = createContext(null);
 +export function ContractsProvider({ children }) {
 +  const [validators, setValidators] = useState(null);
 +  useEffect(() => {
 +    (async () => {
 +      try {
 +        const data = await loadSchemas('/api');
 +        if (!data) return;
 +        const v = buildValidators(data.schemas);
 +        setValidators(v);
 +      } catch (e) {
 +        console.error('Contracts load failed', e);
 +      }
 +    })();
 +  }, []);
 +  const value = useMemo(() => validators, [validators]);
 +  return <Ctx.Provider value={value}>{children}</Ctx.Provider>;
 +}
 +export function useContracts(){ return useContext(Ctx); }

