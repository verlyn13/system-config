 import React, { useEffect, useState } from 'react';
 import { useParams } from 'react-router-dom';
 import { useContracts } from '../context/ContractsProvider';
 import { assertObs } from '../lib/contracts';
 +import ObserversView from './ObserversView';
@@
 export default function ProjectDetail(){
   const { id } = useParams();
   const [items, setItems] = useState([]);
   const contracts = useContracts();
   useEffect(() => {
     let alive = true;
     (async () => {
       const res = await fetch(`/api/obs/projects/${encodeURIComponent(id)}/observers`).then(r=>r.json());
       const list = res.items || [];
       if (contracts?.validateObs) {
         for (const it of list) assertObs(contracts.validateObs, it);
       }
       if (alive) setItems(list);
     })();
     return () => { alive = false; };
   }, [id, contracts]);
   return (
     <div>
       <h2>Project {id}</h2>
 -     <pre>{JSON.stringify(items, null, 2)}</pre>
 +     <ObserversView items={items} />
     </div>
   );
 }

