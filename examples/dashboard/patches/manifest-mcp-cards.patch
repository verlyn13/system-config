 +import React, { useEffect, useState } from 'react';
 +
 +export default function McpStatusCard(){
 +  const [s, setS] = useState(null);
 +  useEffect(() => { (async () => { try { setS(await (await fetch('/api/mcp/self-status')).json()); } catch {} })(); }, []);
 +  if (!s) return null;
 +  return (
 +    <div style={{border:'1px solid #e5e7eb', borderRadius:8, padding:12, margin:'12px 0'}}>
 +      <strong>MCP Server</strong>
 +      <div style={{display:'grid', gridTemplateColumns:'1fr 1fr', gap:12, marginTop:8}}>
 +        <div>
 +          <div><b>Contract:</b> {s.contractVersion || ''}</div>
 +          <div><b>Schema:</b> {s.schemaVersion || ''}</div>
 +          <div><b>Status:</b> {s.ok ? 'ok' : 'n/a'}</div>
 +        </div>
 +        <div>
 +          <div><b>Time:</b> {s.timestamp || ''}</div>
 +        </div>
 +      </div>
 +    </div>
 +  );
 +}

