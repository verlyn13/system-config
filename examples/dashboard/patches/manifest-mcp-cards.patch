 app.get('/api/obs/projects/:id/manifest', async (req, res) => {
   const id = req.params.id;
   const r = await fetch(`${BRIDGE}/api/projects/${encodeURIComponent(id)}/manifest`, { headers: proxyHeaders() });
   const body = await r.text();
   res.status(r.status).type('application/json').send(body);
 });

 app.get('/api/mcp/self-status', async (req, res) => {
   const svc = await fetch(`${BRIDGE}/api/discovery/services`, { headers: proxyHeaders() }).then(r=>r.json());
   if (!svc.mcp?.self_status) return res.status(404).json({ error: 'mcp not configured' });
   const s = await fetch(svc.mcp.self_status, { headers: proxyHeaders() });
   res.status(s.status).type('application/json').send(await s.text());
 });

diff --git a/src/components/ManifestCard.jsx b/src/components/ManifestCard.jsx
new file mode 100644
index 0000000..1111111 100644
--- /dev/null
+++ b/src/components/ManifestCard.jsx
@@
 +import React, { useEffect, useState } from 'react';
 +
 +function toYAML(obj, indent = 0) {
 +  const sp = '  '.repeat(indent);
 +  if (obj === null) return 'null';
 +  if (typeof obj !== 'object') return JSON.stringify(obj);
 +  if (Array.isArray(obj)) return obj.map(v => `${sp}- ${toYAML(v, indent + 1).replace(/^\s+/, '')}`).join('\n');
 +  return Object.entries(obj).map(([k, v]) => {
 +    if (v && typeof v === 'object') return `${sp}${k}:\n${toYAML(v, indent + 1)}`;
 +    return `${sp}${k}: ${toYAML(v, 0)}`;
 +  }).join('\n');
 +}
 +
 +export default function ManifestCard({ projectId }){
 +  const [data, setData] = useState(null);
 +  const [mode, setMode] = useState('yaml');
 +  useEffect(() => {
 +    (async () => {
 +      try { setData(await (await fetch(`/api/obs/projects/${encodeURIComponent(projectId)}/manifest`)).json()); } catch {}
 +    })();
 +  }, [projectId]);
 +  if (!data) return null;
 +  const valid = data.valid !== false;
 +  return (
 +    <div style={{border:'1px solid #e5e7eb', borderRadius:8, padding:12, margin:'12px 0'}}>
 +      <div style={{display:'flex', justifyContent:'space-between'}}>
 +        <strong>Manifest Validation</strong>
 +        <div>
 +          <button onClick={()=>setMode('yaml')} disabled={mode==='yaml'}>YAML</button>
 +          <button onClick={()=>setMode('json')} disabled={mode==='json'} style={{marginLeft:8}}>JSON</button>
 +        </div>
 +      </div>
 +      <div style={{marginTop:8}}>
 +        <div><b>Status:</b> {valid ? 'valid' : 'invalid'}</div>
 +        {!valid && <pre style={{color:'#dc2626'}}>{JSON.stringify(data.errors, null, 2)}</pre>}
 +        <pre style={{maxHeight:260, overflow:'auto', background:'#f9fafb', padding:8}}>
 +          {mode === 'yaml' ? toYAML(data.manifest || {}) : JSON.stringify(data.manifest || {}, null, 2)}
 +        </pre>
 +      </div>
 +    </div>
 +  );
 +}

