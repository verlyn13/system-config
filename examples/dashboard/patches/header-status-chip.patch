 +import React, { useEffect, useState } from 'react';
 +
 +function Chip({ label, ok }){
 +  const color = ok ? '#16a34a' : '#f59e0b';
 +  return <span style={{marginLeft:8, padding:'2px 6px', borderRadius:4, background:color, color:'#fff', fontSize:12}}>{label}</span>;
 +}
 +
 +export default function GlobalStatus(){
 +  const [bridge, setBridge] = useState({ ok: null });
 +  const [mcp, setMcp] = useState({ ok: null });
 +  useEffect(() => {
 +    (async () => {
 +      try { setBridge(await (await fetch('/api/health')).json()); } catch {}
 +      try { setMcp(await (await fetch('/api/mcp/self-status')).json()); } catch {}
 +    })();
 +  }, []);
 +  return (
 +    <div style={{position:'fixed', top:8, right:8, zIndex:9999}}>
 +      <Chip label={`Bridge: ${bridge?.ok ? 'OK' : 'Checking'}`} ok={!!bridge?.ok} />
 +      <Chip label={`MCP: ${mcp?.ok ? 'OK' : 'Checking'}`} ok={!!mcp?.ok} />
 +    </div>
 +  );
 +}

