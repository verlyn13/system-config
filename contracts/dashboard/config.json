{
  "apiVersion": "config.v1",
  "kind": "DashboardConfiguration",
  "metadata": {
    "name": "system-dashboard",
    "description": "Central system compliance dashboard configuration"
  },
  "spec": {
    "server": {
      "host": "localhost",
      "port": 8089,
      "url": "http://localhost:8089",
      "description": "THIS IS THE ONLY DASHBOARD PORT. All dashboards use port 8089."
    },
    "endpoints": {
      "ui": "http://localhost:8089",
      "api": "http://localhost:8089/api",
      "health": "http://localhost:8089/health",
      "stream": "http://localhost:8089/api/stream"
    },
    "files": {
      "server": "dashboard-server.js",
      "client": "index.html",
      "startup": "start-dashboard.sh"
    },
    "features": {
      "realtime_updates": true,
      "sse_enabled": true,
      "auto_refresh": 30000,
      "cache_ttl": 30000
    }
  },
  "status": {
    "verified": true,
    "lastVerified": "2025-09-28T00:00:00Z",
    "notes": "Single source of truth for dashboard configuration"
  }
}