{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.local/schemas/obs.line.v1.json",
  "title": "Observation Line Schema",
  "description": "Contract schema for streaming observation lines",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "apiVersion",
    "run_id",
    "timestamp",
    "project_id",
    "observer",
    "summary",
    "metrics",
    "status"
  ],
  "properties": {
    "apiVersion": {
      "const": "obs.v1",
      "description": "API version identifier"
    },
    "run_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this observation run"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the observation"
    },
    "project_id": {
      "type": "string",
      "pattern": "^[a-z]+:[a-z0-9-]+/[a-z0-9-]+$",
      "description": "Encoded project identifier (service:org/repo)"
    },
    "observer": {
      "type": "string",
      "enum": ["git", "mise", "sbom", "build", "manifest"],
      "description": "External observer name (never internal names)"
    },
    "summary": {
      "type": "string",
      "maxLength": 500,
      "description": "Human-readable summary of the observation"
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["duration_ms"],
      "properties": {
        "duration_ms": {
          "type": "number",
          "minimum": 0,
          "description": "Operation duration in milliseconds"
        },
        "files_processed": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of files processed"
        },
        "errors": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of errors encountered"
        },
        "warnings": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of warnings encountered"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0,
          "description": "Total size processed in bytes"
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["pending", "in_progress", "completed", "failed", "blocked"],
      "description": "Current status of the observation"
    },
    "details": {
      "type": "object",
      "description": "Observer-specific details",
      "additionalProperties": true
    },
    "error": {
      "type": "string",
      "description": "Error message if status is failed"
    },
    "parent_run_id": {
      "type": "string",
      "format": "uuid",
      "description": "Parent observation run ID for nested operations"
    }
  },
  "if": {
    "properties": {
      "status": {
        "const": "failed"
      }
    }
  },
  "then": {
    "required": ["error"]
  }
}