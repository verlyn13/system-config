{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://system.local/schemas/project-manifest.v1.json",
  "title": "Project Manifest",
  "description": "Standard project manifest for system configuration",
  "type": "object",
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec",
    "status"
  ],
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "const": "manifest.v1",
      "description": "API version identifier"
    },
    "kind": {
      "const": "ProjectManifest",
      "description": "Resource kind"
    },
    "metadata": {
      "type": "object",
      "required": ["name", "repository", "created", "updated"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Project name (lowercase, hyphenated)"
        },
        "repository": {
          "type": "string",
          "format": "uri",
          "description": "Git repository URL"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description"
        },
        "created": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        },
        "updated": {
          "type": "string",
          "format": "date-time",
          "description": "Last update timestamp"
        },
        "labels": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "description": "Key-value labels"
        }
      }
    },
    "spec": {
      "type": "object",
      "required": ["type", "language", "runtime", "dependencies", "contracts", "health"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "enum": ["service", "library", "tool", "documentation"],
          "description": "Project type"
        },
        "language": {
          "enum": ["go", "node", "python", "mixed"],
          "description": "Primary language"
        },
        "runtime": {
          "type": "object",
          "required": ["version", "platform"],
          "properties": {
            "version": {
              "type": "string",
              "description": "Runtime version"
            },
            "platform": {
              "type": "string",
              "description": "Platform identifier"
            }
          }
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "type"],
            "properties": {
              "name": {
                "type": "string"
              },
              "type": {
                "enum": ["service", "database", "cache", "queue", "external"]
              },
              "required": {
                "type": "boolean",
                "default": true
              },
              "endpoint": {
                "type": "string",
                "format": "uri"
              }
            }
          }
        },
        "contracts": {
          "type": "object",
          "required": ["enabled", "mode", "slo"],
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Contract enforcement enabled"
            },
            "mode": {
              "enum": ["enforce", "monitor", "disabled"],
              "description": "Enforcement mode"
            },
            "slo": {
              "type": "object",
              "required": ["response_time_p95", "error_rate", "availability"],
              "properties": {
                "response_time_p95": {
                  "type": "number",
                  "description": "95th percentile response time in ms"
                },
                "error_rate": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1,
                  "description": "Maximum error rate (0-1)"
                },
                "availability": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 100,
                  "description": "Minimum availability percentage"
                }
              }
            },
            "observers": {
              "type": "array",
              "items": {
                "enum": ["git", "mise", "sbom", "build", "manifest"]
              },
              "description": "Active observers for this project"
            }
          }
        },
        "health": {
          "type": "object",
          "required": ["endpoint", "interval"],
          "properties": {
            "endpoint": {
              "type": "string",
              "description": "Health check endpoint"
            },
            "interval": {
              "type": "number",
              "description": "Check interval in seconds"
            },
            "timeout": {
              "type": "number",
              "description": "Timeout in seconds"
            }
          }
        },
        "endpoints": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "url", "type"],
            "properties": {
              "name": {
                "type": "string"
              },
              "url": {
                "type": "string",
                "format": "uri"
              },
              "type": {
                "enum": ["http", "grpc", "websocket", "sse"]
              },
              "public": {
                "type": "boolean",
                "default": false
              }
            }
          }
        },
        "mcp": {
          "type": "object",
          "description": "MCP server configuration",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "transport": {
              "enum": ["stdio", "http", "websocket"]
            },
            "tools": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "status": {
      "type": "object",
      "required": ["phase", "conditions"],
      "additionalProperties": false,
      "properties": {
        "phase": {
          "enum": ["initializing", "running", "degraded", "stopped", "error"],
          "description": "Current phase"
        },
        "message": {
          "type": "string",
          "description": "Human-readable status message"
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "status", "lastTransition"],
            "properties": {
              "type": {
                "type": "string"
              },
              "status": {
                "enum": ["True", "False", "Unknown"]
              },
              "reason": {
                "type": "string"
              },
              "message": {
                "type": "string"
              },
              "lastTransition": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        },
        "metrics": {
          "type": "object",
          "properties": {
            "response_time_p95": {
              "type": "number"
            },
            "error_rate": {
              "type": "number"
            },
            "availability": {
              "type": "number"
            },
            "requests_per_second": {
              "type": "number"
            }
          }
        },
        "lastObservation": {
          "type": "string",
          "format": "date-time",
          "description": "Last observation timestamp"
        }
      }
    }
  }
}