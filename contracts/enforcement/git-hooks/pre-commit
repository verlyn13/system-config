#!/bin/bash

# Contract Enforcement Pre-Commit Hook
# Ensures all code changes comply with contract system before commit

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo -e "${BLUE}🔒 Contract Enforcement Pre-Commit Check${NC}"
echo "=========================================="

# Detect repository type
REPO_NAME=$(basename $(git rev-parse --show-toplevel))
SERVICE_TYPE=""

case "$REPO_NAME" in
    ds-go)
        SERVICE_TYPE="go"
        ;;
    devops-mcp)
        SERVICE_TYPE="node"
        ;;
    system-dashboard)
        SERVICE_TYPE="react"
        ;;
    system-setup-update)
        SERVICE_TYPE="system"
        ;;
    *)
        SERVICE_TYPE="unknown"
        ;;
esac

echo "Repository: $REPO_NAME (Type: $SERVICE_TYPE)"

# Function to check for contract violations
check_contracts() {
    local violations=0

    # 1. Check for internal observer names in code
    echo -e "\n${BLUE}Checking for internal observer names...${NC}"

    # Get staged files
    staged_files=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(js|ts|go|py|jsx|tsx)$' || true)

    if [ -n "$staged_files" ]; then
        for file in $staged_files; do
            # Check for internal observer names
            if grep -q '"observer".*"repo"' "$file" 2>/dev/null || \
               grep -q "'observer'.*'repo'" "$file" 2>/dev/null || \
               grep -q 'observer.*=.*"repo"' "$file" 2>/dev/null; then
                echo -e "${RED}❌ Found internal observer 'repo' in $file${NC}"
                echo "   Change to 'git' for external APIs"
                ((violations++))
            fi

            if grep -q '"observer".*"deps"' "$file" 2>/dev/null || \
               grep -q "'observer'.*'deps'" "$file" 2>/dev/null || \
               grep -q 'observer.*=.*"deps"' "$file" 2>/dev/null; then
                echo -e "${RED}❌ Found internal observer 'deps' in $file${NC}"
                echo "   Change to 'mise' for external APIs"
                ((violations++))
            fi

            if grep -q '"observer".*"quality"' "$file" 2>/dev/null || \
               grep -q "'observer'.*'quality'" "$file" 2>/dev/null || \
               grep -q 'observer.*=.*"quality"' "$file" 2>/dev/null; then
                echo -e "${RED}❌ Found blocked observer 'quality' in $file${NC}"
                echo "   Remove from external APIs - this observer is internal only"
                ((violations++))
            fi
        done
    fi

    # 2. Check for missing apiVersion in observations
    echo -e "\n${BLUE}Checking observation structure...${NC}"

    for file in $staged_files; do
        # Look for observation objects without apiVersion
        if grep -E '(observation|obs|event).*=.*\{' "$file" 2>/dev/null | grep -v apiVersion >/dev/null 2>&1; then
            # More detailed check needed
            if grep -A 10 -E '(observation|obs|event).*=.*\{' "$file" 2>/dev/null | grep -q 'observer\|run_id\|timestamp'; then
                if ! grep -A 10 -E '(observation|obs|event).*=.*\{' "$file" 2>/dev/null | grep -q 'apiVersion'; then
                    echo -e "${YELLOW}⚠️  Possible missing apiVersion in observation: $file${NC}"
                    echo "   All observations must have apiVersion: 'obs.v1'"
                fi
            fi
        fi
    done

    # 3. Check project_id format
    echo -e "\n${BLUE}Checking project_id format...${NC}"

    for file in $staged_files; do
        # Check for malformed project IDs
        if grep -E 'project_id.*[A-Z]' "$file" 2>/dev/null | grep -v '//\|#\|/\*' >/dev/null 2>&1; then
            echo -e "${YELLOW}⚠️  Found uppercase in project_id: $file${NC}"
            echo "   Project IDs must be lowercase (service:org/repo)"
        fi

        if grep -E 'project_id.*"[^:]*/"' "$file" 2>/dev/null | grep -v '//\|#\|/\*' >/dev/null 2>&1; then
            echo -e "${RED}❌ Found malformed project_id in $file${NC}"
            echo "   Format must be: service:org/repo"
            ((violations++))
        fi
    done

    # 4. Service-specific checks
    case "$SERVICE_TYPE" in
        go)
            echo -e "\n${BLUE}Go-specific contract checks...${NC}"
            # Check for contract validation in handlers
            if [ -f "internal/contracts/validation.go" ]; then
                echo -e "${GREEN}✅ Contract validation module found${NC}"
            else
                echo -e "${YELLOW}⚠️  Contract validation module not found${NC}"
                echo "   Expected at: internal/contracts/validation.go"
            fi
            ;;
        node)
            echo -e "\n${BLUE}Node.js-specific contract checks...${NC}"
            # Check for contract middleware
            if [ -f "src/contracts/index.js" ] || [ -f "server/contracts/validator.js" ]; then
                echo -e "${GREEN}✅ Contract validation module found${NC}"
            else
                echo -e "${YELLOW}⚠️  Contract validation module not found${NC}"
                echo "   Expected at: src/contracts/index.js"
            fi
            ;;
    esac

    return $violations
}

# Function to validate schemas
validate_schemas() {
    echo -e "\n${BLUE}Validating JSON schemas...${NC}"

    # Check if any schema files are being modified
    schema_files=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.json$' | grep -i schema || true)

    if [ -n "$schema_files" ]; then
        for file in $schema_files; do
            if python3 -m json.tool "$file" >/dev/null 2>&1; then
                echo -e "${GREEN}✅ Valid JSON: $file${NC}"
            else
                echo -e "${RED}❌ Invalid JSON: $file${NC}"
                return 1
            fi
        done
    fi

    return 0
}

# Function to check OPA policy syntax
check_opa_policies() {
    echo -e "\n${BLUE}Checking OPA policies...${NC}"

    rego_files=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.rego$' || true)

    if [ -n "$rego_files" ]; then
        if command -v opa &> /dev/null; then
            for file in $rego_files; do
                if opa fmt --diff "$file" 2>/dev/null | grep -q '^[-+]'; then
                    echo -e "${YELLOW}⚠️  OPA policy needs formatting: $file${NC}"
                    echo "   Run: opa fmt -w $file"
                fi

                # Check for rego.v1 import
                if ! grep -q "import rego.v1" "$file"; then
                    echo -e "${RED}❌ Missing 'import rego.v1' in $file${NC}"
                    echo "   OPA 1.8 requires rego.v1 import"
                    return 1
                fi
            done
        else
            echo -e "${YELLOW}⚠️  OPA not installed - skipping policy checks${NC}"
        fi
    fi

    return 0
}

# Function to run contract tests
run_contract_tests() {
    echo -e "\n${BLUE}Running contract tests...${NC}"

    case "$SERVICE_TYPE" in
        go)
            if [ -f "Makefile" ] && grep -q "test-contracts" "Makefile"; then
                echo "Running Go contract tests..."
                if make test-contracts 2>/dev/null; then
                    echo -e "${GREEN}✅ Contract tests passed${NC}"
                else
                    echo -e "${RED}❌ Contract tests failed${NC}"
                    return 1
                fi
            fi
            ;;
        node)
            if [ -f "package.json" ] && grep -q "test:contracts" "package.json"; then
                echo "Running Node.js contract tests..."
                if npm run test:contracts 2>/dev/null; then
                    echo -e "${GREEN}✅ Contract tests passed${NC}"
                else
                    echo -e "${RED}❌ Contract tests failed${NC}"
                    return 1
                fi
            fi
            ;;
    esac

    return 0
}

# Main execution
TOTAL_VIOLATIONS=0

# Run all checks
check_contracts
TOTAL_VIOLATIONS=$?

if ! validate_schemas; then
    ((TOTAL_VIOLATIONS++))
fi

if ! check_opa_policies; then
    ((TOTAL_VIOLATIONS++))
fi

# Only run tests if explicitly enabled (can be slow)
if [ "${RUN_CONTRACT_TESTS}" = "true" ]; then
    if ! run_contract_tests; then
        ((TOTAL_VIOLATIONS++))
    fi
fi

# Final summary
echo ""
echo "=========================================="

if [ $TOTAL_VIOLATIONS -eq 0 ]; then
    echo -e "${GREEN}✅ Contract enforcement check passed!${NC}"
    echo "Your commit complies with contract requirements."
    exit 0
else
    echo -e "${RED}❌ Contract enforcement check failed!${NC}"
    echo "Found $TOTAL_VIOLATIONS violation(s)."
    echo ""
    echo "To fix:"
    echo "1. Review the errors above"
    echo "2. Fix the contract violations"
    echo "3. Stage your fixes: git add <files>"
    echo "4. Retry the commit"
    echo ""
    echo "To bypass (NOT RECOMMENDED):"
    echo "  git commit --no-verify"
    exit 1
fi