{
  "$schema": "https://json.schemastore.org/mcp-servers.json",
  "_comment": "Global MCP baseline synced by scripts/sync-mcp.sh. Project-specific servers belong in each project's .mcp.json. GitHub MCP is rendered per-host by sync-mcp.sh (stdio wrapper for Claude/Cursor/Windsurf, direct remote for Codex, built-in for Copilot) and is intentionally absent from this baseline.",
  "mcpServers": {
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp",
      "_description": "Developer documentation lookup"
    },
    "memory": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "env": {
        "MEMORY_FILE_PATH": "${HOME}/.local/share/ai-memory/global-memory.jsonl"
      },
      "_description": "Cross-session persistent memory"
    },
    "sequential-thinking": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      "_description": "Complex problem decomposition"
    },
    "brave-search": {
      "type": "stdio",
      "command": "${HOME}/.local/bin/mcp-brave-search-server",
      "_description": "Web search via Brave"
    },
    "firecrawl": {
      "type": "stdio",
      "command": "${HOME}/.local/bin/mcp-firecrawl-server",
      "_description": "Web scraping/crawling"
    }
  }
}
