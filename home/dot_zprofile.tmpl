# ~/.zprofile — Login shell init. Runs once per session.
# RULE: PATH setup only. No interactive features.

# Homebrew (Apple Silicon)
if [[ -x {{ .homebrew.prefix }}/bin/brew ]]; then
  eval "$({{ .homebrew.prefix }}/bin/brew shellenv)"
fi

path_prepend() { [[ -d "$1" ]] && [[ ":$PATH:" != *":$1:"* ]] && PATH="$1:$PATH"; }

# User binaries
path_prepend "$HOME/.local/bin"

# npm global packages
path_prepend "$HOME/.npm-global/bin"

# mise shims (global tool versions)
path_prepend "$XDG_DATA_HOME/mise/shims"
{{ if (.android | default false) -}}

# Android SDK tools
path_prepend "$ANDROID_HOME/platform-tools"
path_prepend "$ANDROID_HOME/emulator"
path_prepend "$ANDROID_HOME/cmdline-tools/latest/bin"
{{ end -}}

export PATH
unset -f path_prepend
