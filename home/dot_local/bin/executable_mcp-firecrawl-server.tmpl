#!/usr/bin/env bash
# mcp-firecrawl-server — runtime secret wrapper for the global Firecrawl MCP server

set -euo pipefail

# Host-capability-substrate secret plane — same contract as direnvrc host_secret_read.
: "${HCS_SECRET_ACCOUNT:=my.1password.com}"
: "${HCS_SECRET_TIMEOUT:=10}"

load_secret() {
  if [[ -n "${FIRECRAWL_API_KEY:-}" ]]; then
    return 0
  fi

  if command -v op >/dev/null 2>&1 && command -v timeout >/dev/null 2>&1; then
    FIRECRAWL_API_KEY="$(timeout "$HCS_SECRET_TIMEOUT" op read --account "$HCS_SECRET_ACCOUNT" 'op://Dev/firecrawl/api-key' 2>/dev/null || true)"
    export FIRECRAWL_API_KEY
  fi

  if [[ -z "${FIRECRAWL_API_KEY:-}" ]]; then
    echo "mcp-firecrawl-server: unable to resolve FIRECRAWL_API_KEY within ${HCS_SECRET_TIMEOUT}s; set env var or check 1Password" >&2
    exit 1
  fi
}

load_secret
exec npx -y firecrawl-mcp "$@"
