#!/usr/bin/env bash
# mcp-github-server — stdio wrapper that relays to GitHub's remote MCP server.
#
# This wrapper exists for hosts where a self-contained stdio server is more
# reliable than requiring a launch-time GITHUB_PAT env var or following GitHub's
# OAuth discovery path. See docs/mcp-config.md and docs/github-mcp.md for the
# per-host framework.
#
# Reads a fine-grained PAT from env or 1Password at launch and proxies
# stdio MCP traffic to GitHub's remote MCP server over Streamable HTTP
# via `mcp-remote`. Curated toolsets are passed via X-MCP-Toolsets.
#
# Invariants:
#   - The PAT is never stored in a persistent config file.
#   - mcp-remote runs with --silent so the Authorization header is never
#     written to stderr (and therefore not into host log files).
#   - The version of mcp-remote is pinned for reproducibility.

set -euo pipefail

# Host-capability-substrate secret plane — same contract as direnvrc host_secret_read.
: "${HCS_SECRET_ACCOUNT:=my.1password.com}"
: "${HCS_SECRET_TIMEOUT:=10}"

OP_URI="op://Dev/github-mcp/token"
REMOTE_URL="https://api.githubcopilot.com/mcp/"
MCP_REMOTE_VERSION="0.1.38"
TOOLSETS="context,repos,issues,pull_requests,users,actions,code_security,dependabot,discussions,gists,labels,orgs,projects,releases,security_advisories,secret_protection,github_support_docs_search"

if [[ -z "${GITHUB_PAT:-}" ]] && command -v op >/dev/null 2>&1 && command -v timeout >/dev/null 2>&1; then
  GITHUB_PAT="$(timeout "$HCS_SECRET_TIMEOUT" op read --account "$HCS_SECRET_ACCOUNT" "$OP_URI" 2>/dev/null || true)"
  export GITHUB_PAT
fi

if [[ -z "${GITHUB_PAT:-}" ]]; then
  echo "mcp-github-server: unable to resolve GITHUB_PAT within ${HCS_SECRET_TIMEOUT}s; set env var or check 1Password ($OP_URI)" >&2
  exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

exec "$SCRIPT_DIR/mcp-npx" -y "mcp-remote@${MCP_REMOTE_VERSION}" \
  "$REMOTE_URL" \
  --transport http-only \
  --silent \
  --header "Authorization: Bearer ${GITHUB_PAT}" \
  --header "X-MCP-Toolsets: ${TOOLSETS}"
