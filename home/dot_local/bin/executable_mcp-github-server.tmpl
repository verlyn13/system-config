#!/usr/bin/env bash
# mcp-github-server — stdio wrapper that relays to GitHub's remote MCP server.
#
# Reads a fine-grained PAT from env or 1Password at launch and proxies
# stdio MCP traffic to https://api.githubcopilot.com/mcp/x/all over
# Streamable HTTP via `mcp-remote`.
#
# Invariants:
#   - The PAT is never stored in a persistent config file.
#   - mcp-remote runs with --silent so the Authorization header is never
#     written to stderr (and therefore not into host log files).
#   - The version of mcp-remote is pinned for reproducibility.

set -euo pipefail

OP_ACCOUNT="my.1password.com"
OP_URI="op://Dev/github-mcp/token"
REMOTE_URL="https://api.githubcopilot.com/mcp/x/all"
MCP_REMOTE_VERSION="0.1.38"

if [[ -z "${GITHUB_PERSONAL_ACCESS_TOKEN:-}" ]] && command -v op >/dev/null 2>&1; then
  GITHUB_PERSONAL_ACCESS_TOKEN="$(op read --account "$OP_ACCOUNT" "$OP_URI" 2>/dev/null || true)"
  export GITHUB_PERSONAL_ACCESS_TOKEN
fi

if [[ -z "${GITHUB_PERSONAL_ACCESS_TOKEN:-}" ]]; then
  echo "mcp-github-server: set GITHUB_PERSONAL_ACCESS_TOKEN or store PAT in $OP_URI" >&2
  exit 1
fi

exec npx -y "mcp-remote@${MCP_REMOTE_VERSION}" \
  "$REMOTE_URL" \
  --transport http-only \
  --silent \
  --header "Authorization: Bearer ${GITHUB_PERSONAL_ACCESS_TOKEN}"
