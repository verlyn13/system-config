#!/usr/bin/env bash
# mcp-runpod-server — runtime secret wrapper for the global Runpod API MCP server

set -euo pipefail

# Host-capability-substrate secret plane — same contract as direnvrc host_secret_read.
# Timeout is wrapper-budget (10s), longer than direnv's 5s; MCP clients tolerate ~15-30s init.
: "${HCS_SECRET_ACCOUNT:=my.1password.com}"
: "${HCS_SECRET_TIMEOUT:=10}"

load_secret() {
  if [[ -n "${RUNPOD_API_KEY:-}" ]]; then
    return 0
  fi

  if command -v op >/dev/null 2>&1 && command -v timeout >/dev/null 2>&1; then
    RUNPOD_API_KEY="$(timeout "$HCS_SECRET_TIMEOUT" op read --account "$HCS_SECRET_ACCOUNT" 'op://Dev/runpod-api/api-key' 2>/dev/null || true)"
    export RUNPOD_API_KEY
  fi

  if [[ -z "${RUNPOD_API_KEY:-}" ]]; then
    echo "mcp-runpod-server: unable to resolve RUNPOD_API_KEY within ${HCS_SECRET_TIMEOUT}s; set env var or check 1Password" >&2
    exit 1
  fi
}

load_secret
exec npx -y @runpod/mcp-server@latest "$@"
