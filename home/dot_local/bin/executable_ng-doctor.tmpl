#!/usr/bin/env bash
# shellcheck disable=SC2088
# ng-doctor — system-config development machine verification harness
# Delivered via chezmoi from home/dot_local/bin/ng-doctor.tmpl
# Contract: AGENTS.md
#
# Exit codes:
#   0 — all checks passed (or skipped)
#   1 — one or more checks failed
#
# Usage:
#   ng-doctor              # run all checks
#   ng-doctor <category>   # run checks for one category
#   ng-doctor --list       # list all checks
#   ng-doctor --summary    # compact pass/fail/skip counts

set -euo pipefail

# --- Configuration -----------------------------------------------------------

SYSTEM_CONFIG_DIR='{{ .chezmoi.workingTree }}'
HOMEBREW_PREFIX='{{ .homebrew_prefix | default "/opt/homebrew" }}'
CHEZMOI_SOURCE='{{ .chezmoi.sourceDir }}'
OP_ACCOUNT="my.1password.com"
OP_VAULT="Dev"
OP_SSH_AGENT_SOCKET="$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
OP_SSH_AGENT_CONFIG="$HOME/.config/1Password/ssh/agent.toml"
OP_SSH_SIGN_PROGRAM="/Applications/1Password.app/Contents/MacOS/op-ssh-sign"

# --- Output helpers -----------------------------------------------------------

_pass=0
_fail=0
_skip=0

pass() {
  local name="$1" desc="$2"
  printf '\033[32m✓\033[0m %s: %s\n' "$name" "$desc"
  (( _pass++ )) || true
}

fail() {
  local name="$1" desc="$2" expected="$3" got="$4"
  printf '\033[31m✗\033[0m %s: %s — EXPECTED: %s, GOT: %s\n' "$name" "$desc" "$expected" "$got"
  (( _fail++ )) || true
}

skip() {
  local name="$1" reason="$2"
  printf '\033[33m⊘\033[0m %s: skipped (%s)\n' "$name" "$reason"
  (( _skip++ )) || true
}

section() {
  printf '\n\033[1m[%s]\033[0m\n' "$1"
}

expand_tilde() {
  local path="$1"
  case "$path" in
    "~")
      printf '%s' "$HOME"
      ;;
    "~/"*)
      printf '%s/%s' "$HOME" "${path#"~/"}"
      ;;
    *)
      printf '%s' "$path"
      ;;
  esac
}

ssh_resolved_value() {
  local host="$1" key="$2"
  if ! command -v ssh &>/dev/null; then
    return 0
  fi
  ssh -G "$host" 2>/dev/null | awk -v key="$key" '$1 == key { $1=""; sub(/^ /, ""); print; exit }'
}

# --- Category: shell ----------------------------------------------------------

get_login_shell() {
  local actual=""

  if command -v dscl &>/dev/null; then
    actual=$(dscl . -read /Users/"$USER" UserShell 2>/dev/null | awk '{print $2}' || true)
  fi

  if [[ -z "$actual" ]] && command -v python3 &>/dev/null; then
    actual=$(python3 - <<'PY' 2>/dev/null || true
import os
import pwd

print(pwd.getpwnam(os.environ["USER"]).pw_shell)
PY
)
  fi

  printf '%s' "$actual"
}

check_login_shell_is_zsh() {
  local actual
  actual="$(get_login_shell)"
  if [[ "$actual" == "/bin/zsh" ]]; then
    pass "login_shell_is_zsh" "Login shell is /bin/zsh"
  else
    fail "login_shell_is_zsh" "Login shell" "/bin/zsh" "${actual:-unknown}"
  fi
}

check_homebrew_bash_installed() {
  if [[ -x "${HOMEBREW_PREFIX}/bin/bash" ]]; then
    pass "homebrew_bash_installed" "Homebrew bash installed"
  else
    fail "homebrew_bash_installed" "Homebrew bash" "${HOMEBREW_PREFIX}/bin/bash" "not found"
  fi
}

check_zshenv_is_minimal() {
  local zshenv="$HOME/.zshenv"
  if [[ ! -f "$zshenv" ]]; then
    skip "zshenv_is_minimal" ".zshenv does not exist yet"
    return
  fi
  local lines
  lines=$(grep -cve '^\s*$' -e '^\s*#' "$zshenv" 2>/dev/null || echo 0)
  if (( lines <= 15 )); then
    pass "zshenv_is_minimal" ".zshenv has ${lines} non-comment lines (<=15)"
  else
    fail "zshenv_is_minimal" ".zshenv line count" "<=15" "$lines"
  fi
}

check_zshrc_loads_modules() {
  local zshrc="$HOME/.zshrc"
  if [[ ! -f "$zshrc" ]]; then
    skip "zshrc_loads_modules" ".zshrc does not exist yet"
    return
  fi
  if grep -q 'zshrc\.d' "$zshrc" 2>/dev/null; then
    pass "zshrc_loads_modules" ".zshrc sources zshrc.d/ modules"
  else
    fail "zshrc_loads_modules" ".zshrc module loading" "sources zshrc.d/*.zsh" "no zshrc.d reference found"
  fi
}

check_zshrc_d_modules_present() {
  local moddir="$HOME/.config/zshrc.d"
  if [[ ! -d "$moddir" ]]; then
    skip "zshrc_d_modules_present" "zshrc.d/ does not exist yet"
    return
  fi
  local count
  count=$(find "$moddir" -name '*.zsh' -type f 2>/dev/null | wc -l | tr -d ' ')
  if (( count >= 10 )); then
    pass "zshrc_d_modules_present" "${count} modules in zshrc.d/"
  else
    fail "zshrc_d_modules_present" "Module count" ">=10" "$count"
  fi
}

check_bash_config_minimal() {
  local bashrc="$HOME/.bashrc"
  if [[ ! -f "$bashrc" ]]; then
    skip "bash_config_minimal" ".bashrc does not exist yet"
    return
  fi
  local lines
  lines=$(grep -cve '^\s*$' -e '^\s*#' "$bashrc" 2>/dev/null || echo 0)
  if (( lines <= 40 )); then
    pass "bash_config_minimal" ".bashrc has ${lines} non-comment lines (<=40)"
  else
    fail "bash_config_minimal" ".bashrc line count" "<=40" "$lines"
  fi
}

run_shell_checks() {
  section "shell"
  check_login_shell_is_zsh
  check_homebrew_bash_installed
  check_zshenv_is_minimal
  check_zshrc_loads_modules
  check_zshrc_d_modules_present
  check_bash_config_minimal
}

# --- Category: path ----------------------------------------------------------

check_homebrew_on_path() {
  if [[ ":$PATH:" == *":${HOMEBREW_PREFIX}/bin:"* ]]; then
    pass "homebrew_on_path" "Homebrew bin on PATH"
  else
    fail "homebrew_on_path" "PATH entry" "${HOMEBREW_PREFIX}/bin" "not in PATH"
  fi
}

check_local_bin_on_path() {
  if [[ ":$PATH:" == *":$HOME/.local/bin:"* ]]; then
    pass "local_bin_on_path" "~/.local/bin on PATH"
  else
    fail "local_bin_on_path" "PATH entry" "~/.local/bin" "not in PATH"
  fi
}

check_mise_shims_on_path() {
  local shims_dir="$HOME/.local/share/mise/shims"
  if [[ ":$PATH:" == *":${shims_dir}:"* ]]; then
    pass "mise_shims_on_path" "mise shims on PATH"
  else
    fail "mise_shims_on_path" "PATH entry" "$shims_dir" "not in PATH"
  fi
}

check_no_duplicate_path_entries() {
  local dupes
  dupes=$(echo "$PATH" | tr ':' '\n' | sort | uniq -d | head -5)
  if [[ -z "$dupes" ]]; then
    pass "no_duplicate_path_entries" "No duplicate PATH entries"
  else
    fail "no_duplicate_path_entries" "Duplicate PATH entries" "none" "$dupes"
  fi
}

run_path_checks() {
  section "path"
  check_homebrew_on_path
  check_local_bin_on_path
  check_mise_shims_on_path
  check_no_duplicate_path_entries
}

# --- Category: tools ---------------------------------------------------------

_check_tool() {
  local name="$1" cmd="$2"
  if command -v "$cmd" &>/dev/null; then
    pass "${name}" "${cmd} installed"
  else
    fail "${name}" "${cmd}" "installed" "not found"
  fi
}

check_mise_installed() { _check_tool "mise_installed" "mise"; }
check_direnv_installed() { _check_tool "direnv_installed" "direnv"; }
check_chezmoi_installed() { _check_tool "chezmoi_installed" "chezmoi"; }
check_starship_installed() { _check_tool "starship_installed" "starship"; }
check_op_installed() { _check_tool "op_installed" "op"; }
check_cargo_installed() { _check_tool "cargo_installed" "cargo"; }
check_rustc_installed() { _check_tool "rustc_installed" "rustc"; }
check_cargo_clippy_installed() { _check_tool "cargo_clippy_installed" "cargo-clippy"; }

check_op_ready() {
  if ! command -v op &>/dev/null; then
    skip "op_ready" "1Password CLI (op) not installed"
    return
  fi

  local output=""
  if output="$(op vault get "$OP_VAULT" --account "$OP_ACCOUNT" 2>&1 >/dev/null)"; then
    pass "op_ready" "1Password CLI can access ${OP_VAULT} vault on ${OP_ACCOUNT}"
    return
  fi

  case "$output" in
    *"not currently signed in"*|*"not signed in"*|*"signin"*|*"sign in"*)
      fail "op_ready" "1Password vault access" "${OP_VAULT} vault accessible on ${OP_ACCOUNT}" "no authenticated account"
      ;;
    *"desktop app"*|*"CLI integration"*|*"app integration"*|*"Connect with 1Password in the browser"*|*"Integrate with 1Password CLI"*)
      fail "op_ready" "1Password CLI integration" "desktop app integration enabled" "integration not enabled"
      ;;
    *"unknown account"*|*"no account"*)
      fail "op_ready" "1Password account selection" "${OP_ACCOUNT} available to op" "wrong account or account not added"
      ;;
    *"isn't a vault"*|*"vault"*' "'$OP_VAULT'"'*"not found"*|*"not found in"*"$OP_ACCOUNT"*)
      fail "op_ready" "1Password vault access" "${OP_VAULT} vault accessible on ${OP_ACCOUNT}" "vault not found or not accessible"
      ;;
    *"connect"*|*"background"*|*"not running"*|*"IPC"*|*"socket"*)
      fail "op_ready" "1Password app connectivity" "desktop app running in background" "desktop app not running"
      ;;
    *)
      fail "op_ready" "1Password CLI readiness" "${OP_VAULT} vault accessible on ${OP_ACCOUNT}" "${output:-unknown error}"
      ;;
  esac
}

check_mise_activated() {
  if ! command -v mise &>/dev/null; then
    skip "mise_activated" "mise not installed"
    return
  fi
  # mise activation sets MISE_SHELL or the shims dir is functional
  if [[ -n "${MISE_SHELL:-}" ]] || mise current &>/dev/null; then
    pass "mise_activated" "mise is activated"
  else
    fail "mise_activated" "mise activation" "active" "not activated in current shell"
  fi
}

check_direnv_hooked() {
  if ! command -v direnv &>/dev/null; then
    skip "direnv_hooked" "direnv not installed"
    return
  fi
  # Check if direnv hook is present in shell config
  local hooked=false
  if [[ -f "$HOME/.zshrc" ]] && grep -q 'direnv' "$HOME/.zshrc" 2>/dev/null; then
    hooked=true
  fi
  if [[ -d "$HOME/.config/zshrc.d" ]] && grep -rl 'direnv' "$HOME/.config/zshrc.d" &>/dev/null; then
    hooked=true
  fi
  if $hooked; then
    pass "direnv_hooked" "direnv hook found in shell config"
  else
    fail "direnv_hooked" "direnv hook" "in shell config" "not found"
  fi
}

run_tools_checks() {
  section "tools"
  check_mise_installed
  check_mise_activated
  check_direnv_installed
  check_direnv_hooked
  check_chezmoi_installed
  check_starship_installed
  check_cargo_installed
  check_rustc_installed
  check_cargo_clippy_installed
  check_op_installed
  check_op_ready
}

# --- Category: ssh ------------------------------------------------------------

check_ssh_config_exists() {
  local config="$HOME/.ssh/config"
  if [[ -f "$config" ]]; then
    pass "ssh_config_exists" "~/.ssh/config exists"
  else
    fail "ssh_config_exists" "SSH config" "exists at $config" "not found"
  fi
}

check_ssh_config_includes_conf_d() {
  local config="$HOME/.ssh/config"
  if [[ ! -f "$config" ]]; then
    skip "ssh_config_includes_conf_d" "~/.ssh/config not present"
    return
  fi
  if grep -Eq '^[[:space:]]*Include[[:space:]]+~/.ssh/conf\.d/\*\.conf([[:space:]]|$)' "$config"; then
    pass "ssh_config_includes_conf_d" "~/.ssh/config includes ~/.ssh/conf.d/*.conf"
  else
    fail "ssh_config_includes_conf_d" "SSH include" "~/.ssh/conf.d/*.conf" "not configured"
  fi
}

check_ssh_identityagent_is_1password() {
  if ! command -v ssh &>/dev/null; then
    skip "ssh_identityagent_is_1password" "ssh not installed"
    return
  fi
  local agent
  agent="$(ssh_resolved_value github.com identityagent)"
  if [[ -z "$agent" ]] || [[ "$agent" == "none" ]]; then
    fail "ssh_identityagent_is_1password" "SSH IdentityAgent" "$OP_SSH_AGENT_SOCKET" "not configured; enable the 1Password SSH agent and rerun chezmoi apply"
  elif [[ "$agent" == *"2BUA8C4S2C.com.1password/t/agent.sock"* ]]; then
    pass "ssh_identityagent_is_1password" "github.com resolves to 1Password SSH agent"
  else
    fail "ssh_identityagent_is_1password" "SSH IdentityAgent" "$OP_SSH_AGENT_SOCKET" "$agent"
  fi
}

check_ssh_1password_agent_config_exists() {
  if [[ -s "$OP_SSH_AGENT_CONFIG" ]]; then
    pass "ssh_1password_agent_config_exists" "1Password SSH agent config exists at ${OP_SSH_AGENT_CONFIG}"
  else
    fail "ssh_1password_agent_config_exists" "1Password SSH agent config" "non-empty file at ${OP_SSH_AGENT_CONFIG}" "missing or empty"
  fi
}

check_ssh_1password_agent_config_targets_dev_vault() {
  if [[ ! -f "$OP_SSH_AGENT_CONFIG" ]]; then
    skip "ssh_1password_agent_config_targets_dev_vault" "1Password SSH agent config not present"
    return
  fi
  if grep -Eq '^[[:space:]]*vault[[:space:]]*=[[:space:]]*"Dev"[[:space:]]*$' "$OP_SSH_AGENT_CONFIG" \
    && grep -Eq '^[[:space:]]*account[[:space:]]*=[[:space:]]*"my\.1password\.com"[[:space:]]*$' "$OP_SSH_AGENT_CONFIG"; then
    pass "ssh_1password_agent_config_targets_dev_vault" "1Password SSH agent config includes ${OP_ACCOUNT}/${OP_VAULT}"
  else
    fail "ssh_1password_agent_config_targets_dev_vault" "1Password SSH agent config" "entry for account=${OP_ACCOUNT}, vault=${OP_VAULT}" "missing"
  fi
}

check_ssh_agent_socket_exists() {
  if [[ -S "$OP_SSH_AGENT_SOCKET" ]]; then
    pass "ssh_agent_socket_exists" "SSH agent socket exists at ${OP_SSH_AGENT_SOCKET}"
  else
    fail "ssh_agent_socket_exists" "SSH agent socket" "socket at ${OP_SSH_AGENT_SOCKET}" "not found; enable the 1Password SSH agent in the desktop app"
  fi
}

check_ssh_forwardagent_disabled_by_default() {
  if ! command -v ssh &>/dev/null; then
    skip "ssh_forwardagent_disabled_by_default" "ssh not installed"
    return
  fi
  local value
  value="$(ssh_resolved_value ssh-policy-default.invalid forwardagent)"
  if [[ "$value" == "no" ]]; then
    pass "ssh_forwardagent_disabled_by_default" "ForwardAgent disabled by default"
  else
    fail "ssh_forwardagent_disabled_by_default" "Default ForwardAgent" "no" "${value:-unset}"
  fi
}

check_ssh_github_does_not_forward_agent() {
  if ! command -v ssh &>/dev/null; then
    skip "ssh_github_does_not_forward_agent" "ssh not installed"
    return
  fi
  local value
  value="$(ssh_resolved_value github.com forwardagent)"
  if [[ "$value" == "no" ]]; then
    pass "ssh_github_does_not_forward_agent" "github.com does not forward the SSH agent"
  else
    fail "ssh_github_does_not_forward_agent" "GitHub ForwardAgent" "no" "${value:-unset}"
  fi
}

check_git_ssh_signing_configured() {
  if ! command -v git &>/dev/null; then
    skip "git_ssh_signing_configured" "git not installed"
    return
  fi
  local format sign_enabled signing_key signing_program expanded_program
  format="$(git config --global --get gpg.format 2>/dev/null || true)"
  sign_enabled="$(git config --global --get commit.gpgsign 2>/dev/null || true)"
  signing_key="$(git config --global --get user.signingkey 2>/dev/null || true)"
  signing_program="$(git config --global --get gpg.ssh.program 2>/dev/null || true)"
  if [[ "$format" != "ssh" ]] || [[ "$sign_enabled" != "true" ]] || [[ "$signing_key" != *.pub ]]; then
    fail "git_ssh_signing_configured" "Git signing config" "gpg.format=ssh, commit.gpgsign=true, user.signingkey=*.pub" "format=${format:-unset}, commit.gpgsign=${sign_enabled:-unset}, user.signingkey=${signing_key:-unset}"
    return
  fi

  if [[ "$signing_key" == *.1password.pub ]]; then
    if [[ -z "$signing_program" ]]; then
      fail "git_ssh_signing_configured" "Git SSH signing helper" "gpg.ssh.program=${OP_SSH_SIGN_PROGRAM} for 1Password-managed signing keys" "unset"
      return
    fi
    expanded_program="$(expand_tilde "$signing_program")"
    if [[ "$expanded_program" != "$OP_SSH_SIGN_PROGRAM" ]] || [[ ! -x "$expanded_program" ]]; then
      fail "git_ssh_signing_configured" "Git SSH signing helper" "executable 1Password helper at ${OP_SSH_SIGN_PROGRAM}" "${signing_program}"
      return
    fi
  fi

  if [[ "$format" == "ssh" ]] && [[ "$sign_enabled" == "true" ]] && [[ "$signing_key" == *.pub ]]; then
    pass "git_ssh_signing_configured" "Git is configured for SSH commit signing"
  fi
}

check_ssh_allowed_signers_present() {
  if ! command -v git &>/dev/null; then
    skip "ssh_allowed_signers_present" "git not installed"
    return
  fi
  local format signers_file
  format="$(git config --global --get gpg.format 2>/dev/null || true)"
  if [[ "$format" != "ssh" ]]; then
    skip "ssh_allowed_signers_present" "Git SSH signing not configured"
    return
  fi
  signers_file="$(git config --global --get gpg.ssh.allowedsignersfile 2>/dev/null || true)"
  if [[ -z "$signers_file" ]]; then
    fail "ssh_allowed_signers_present" "gpg.ssh.allowedsignersfile" "configured" "unset"
    return
  fi
  local expanded
  expanded="$(expand_tilde "$signers_file")"
  if [[ -s "$expanded" ]]; then
    pass "ssh_allowed_signers_present" "Allowed signers file exists at ${expanded}"
  else
    fail "ssh_allowed_signers_present" "Allowed signers file" "non-empty file at ${expanded}" "missing or empty"
  fi
}

check_ssh_allowed_signers_match_signing_identity() {
  if ! command -v git &>/dev/null; then
    skip "ssh_allowed_signers_match_signing_identity" "git not installed"
    return
  fi
  local format principal signing_key signers_file
  format="$(git config --global --get gpg.format 2>/dev/null || true)"
  if [[ "$format" != "ssh" ]]; then
    skip "ssh_allowed_signers_match_signing_identity" "Git SSH signing not configured"
    return
  fi
  principal="$(git config --global --get user.email 2>/dev/null || true)"
  signing_key="$(git config --global --get user.signingkey 2>/dev/null || true)"
  signers_file="$(git config --global --get gpg.ssh.allowedsignersfile 2>/dev/null || true)"
  if [[ -z "$principal" ]] || [[ -z "$signing_key" ]] || [[ -z "$signers_file" ]]; then
    fail "ssh_allowed_signers_match_signing_identity" "Git SSH signing identity" "user.email, user.signingkey, and gpg.ssh.allowedsignersfile configured" "incomplete config"
    return
  fi

  local expanded_signers expanded_key key_material
  expanded_signers="$(expand_tilde "$signers_file")"
  expanded_key="$(expand_tilde "$signing_key")"
  if [[ ! -s "$expanded_signers" ]]; then
    skip "ssh_allowed_signers_match_signing_identity" "Allowed signers file missing"
    return
  fi
  if [[ ! -f "$expanded_key" ]]; then
    fail "ssh_allowed_signers_match_signing_identity" "Signing key file" "file at ${expanded_key}" "missing"
    return
  fi

  key_material="$(awk 'NF >= 2 { print $1 " " $2; exit }' "$expanded_key")"
  if [[ -z "$key_material" ]]; then
    fail "ssh_allowed_signers_match_signing_identity" "Signing key material" "parseable public key at ${expanded_key}" "unreadable"
    return
  fi

  if grep -Fq "${principal} ${key_material}" "$expanded_signers"; then
    pass "ssh_allowed_signers_match_signing_identity" "Allowed signers file includes the active signing identity"
  else
    fail "ssh_allowed_signers_match_signing_identity" "Allowed signers mapping" "${principal} ${key_material}" "not found in ${expanded_signers}"
  fi
}

run_ssh_checks() {
  section "ssh"
  check_ssh_config_exists
  check_ssh_config_includes_conf_d
  check_ssh_1password_agent_config_exists
  check_ssh_1password_agent_config_targets_dev_vault
  check_ssh_identityagent_is_1password
  check_ssh_agent_socket_exists
  check_ssh_forwardagent_disabled_by_default
  check_ssh_github_does_not_forward_agent
  check_git_ssh_signing_configured
  check_ssh_allowed_signers_present
  check_ssh_allowed_signers_match_signing_identity
}

# --- Category: iterm2 --------------------------------------------------------

check_dynamic_profiles_dir_exists() {
  local dp_dir="$HOME/Library/Application Support/iTerm2/DynamicProfiles"
  if [[ -d "$dp_dir" ]]; then
    pass "dynamic_profiles_dir_exists" "DynamicProfiles directory exists"
  else
    fail "dynamic_profiles_dir_exists" "DynamicProfiles dir" "exists" "not found"
  fi
}

check_managed_profiles_installed() {
  local src_dir="$SYSTEM_CONFIG_DIR/iterm2/profiles"
  local dp_dir="$HOME/Library/Application Support/iTerm2/DynamicProfiles"

  if [[ ! -d "$dp_dir" ]]; then
    skip "managed_profiles_installed" "DynamicProfiles dir missing"
    return
  fi

  if [[ ! -d "$src_dir" ]]; then
    skip "managed_profiles_installed" "iterm2/profiles/ missing in repo"
    return
  fi

  shopt -s nullglob
  local sources=("$src_dir"/*.json)
  shopt -u nullglob

  if [[ ${#sources[@]} -eq 0 ]]; then
    skip "managed_profiles_installed" "no managed profiles in repo (retired state)"
    return
  fi

  local missing=()
  local src name target resolved
  for src in "${sources[@]}"; do
    name="$(basename "$src")"
    target="$dp_dir/$name"
    if [[ -L "$target" ]]; then
      resolved="$(readlink "$target")"
      if [[ "$resolved" == "$src" ]]; then
        continue
      fi
    fi
    missing+=("$name")
  done

  if [[ ${#missing[@]} -eq 0 ]]; then
    pass "managed_profiles_installed" "${#sources[@]} managed profile(s) symlinked into DynamicProfiles"
  else
    fail "managed_profiles_installed" "all managed profiles symlinked" \
         "${#sources[@]} symlink(s)" \
         "${#missing[@]} missing (${missing[*]})"
  fi
}

check_iterm2_shell_integration() {
  local installer="$SYSTEM_CONFIG_DIR/scripts/install-iterm2-shell-integration.sh"

  if [[ ! -d "/Applications/iTerm.app" ]]; then
    skip "iterm2_shell_integration" "iTerm2 not installed"
    return
  fi

  if [[ ! -x "$installer" ]]; then
    skip "iterm2_shell_integration" "installer script missing or not executable"
    return
  fi

  if "$installer" --verify >/dev/null 2>&1; then
    pass "iterm2_shell_integration" "shell-integration script present and SHA matches pinned value"
  else
    local detail
    detail="$("$installer" --verify 2>&1 | head -1 || true)"
    fail "iterm2_shell_integration" "shell-integration script" \
         "present and matches pinned SHA" \
         "${detail:-not verified}"
  fi
}

run_iterm2_checks() {
  section "iterm2"
  check_dynamic_profiles_dir_exists
  check_managed_profiles_installed
  check_iterm2_shell_integration
}

# --- Category: agentic -------------------------------------------------------

check_agentic_mode_loads_minimal() {
  local moddir="$HOME/.config/zshrc.d"
  if [[ ! -d "$moddir" ]]; then
    skip "agentic_mode_loads_minimal" "zshrc.d/ does not exist yet"
    return
  fi
  local agentic_mod="$moddir/30-agentic.zsh"
  if [[ -f "$agentic_mod" ]]; then
    pass "agentic_mode_loads_minimal" "Agentic module exists"
  else
    fail "agentic_mode_loads_minimal" "Agentic module" "$agentic_mod" "not found"
  fi
}

check_agentic_prompt_is_static() {
  local moddir="$HOME/.config/zshrc.d"
  if [[ ! -d "$moddir" ]]; then
    skip "agentic_prompt_is_static" "zshrc.d/ does not exist yet"
    return
  fi
  local agentic_mod="$moddir/30-agentic.zsh"
  if [[ ! -f "$agentic_mod" ]]; then
    skip "agentic_prompt_is_static" "agentic module not installed"
    return
  fi
  if grep -q 'PROMPT=' "$agentic_mod" 2>/dev/null; then
    pass "agentic_prompt_is_static" "Static PROMPT set in agentic module"
  else
    fail "agentic_prompt_is_static" "Agentic prompt" "static PROMPT=" "not found"
  fi
}

check_agentic_startup_under_200ms() {
  if ! command -v zsh &>/dev/null; then
    skip "agentic_startup_under_200ms" "zsh not available"
    return
  fi
  local moddir="$HOME/.config/zshrc.d"
  if [[ ! -d "$moddir" ]]; then
    skip "agentic_startup_under_200ms" "zshrc.d/ does not exist yet"
    return
  fi
  # Measure agentic zsh startup time (3 runs, take median)
  local times=()
  for _ in 1 2 3; do
    local t
    t=$( { TIMEFORMAT='%3R'; time NG_MODE=agentic zsh -lic 'exit' &>/dev/null; } 2>&1 )
    times+=("$t")
  done
  # Sort and take median
  local sorted
  sorted=$(printf '%s\n' "${times[@]}" | sort -n)
  local median
  median=$(echo "$sorted" | sed -n '2p')
  # Convert to ms (median is in seconds like 0.045)
  local ms
  ms=$(echo "$median" | awk '{printf "%.0f", $1 * 1000}')
  if (( ms <= 200 )); then
    pass "agentic_startup_under_200ms" "Agentic zsh startup: ${ms}ms"
  else
    fail "agentic_startup_under_200ms" "Startup time" "<=200ms" "${ms}ms"
  fi
}

run_agentic_checks() {
  section "agentic"
  check_agentic_mode_loads_minimal
  check_agentic_prompt_is_static
  check_agentic_startup_under_200ms
}

# --- Category: filesystem ----------------------------------------------------

check_xdg_dirs_exist() {
  local all_ok=true
  local missing_dirs=""
  for dir in "$HOME/.config" "$HOME/.local/share" "$HOME/.local/state" "$HOME/.cache"; do
    if [[ ! -d "$dir" ]]; then
      all_ok=false
      missing_dirs="${missing_dirs} ${dir}"
    fi
  done
  if $all_ok; then
    pass "xdg_dirs_exist" "XDG base directories exist"
  else
    fail "xdg_dirs_exist" "XDG directories" "all exist" "missing:${missing_dirs}"
  fi
}

check_organizations_dir_exists() {
  if [[ -d "$HOME/Organizations" ]]; then
    pass "organizations_dir_exists" "~/Organizations exists"
  else
    fail "organizations_dir_exists" "Organizations dir" "exists" "not found"
  fi
}

check_system_config_in_correct_location() {
  if [[ -d "$SYSTEM_CONFIG_DIR" ]] && [[ -d "$SYSTEM_CONFIG_DIR/.git" ]]; then
    pass "system_config_in_correct_location" "system-config at ${SYSTEM_CONFIG_DIR}"
  else
    fail "system_config_in_correct_location" "system-config location" "$SYSTEM_CONFIG_DIR" "not found or not a git repo"
  fi
}

check_chezmoi_source_is_repo() {
  if [[ -z "$CHEZMOI_SOURCE" ]]; then
    skip "chezmoi_source_is_repo" "chezmoi not configured"
    return
  fi
  # After P0-3, chezmoi source should point to system-config/home
  if [[ "$CHEZMOI_SOURCE" == *"system-config/home"* ]] && [[ -d "$(dirname "$CHEZMOI_SOURCE")/.git" ]]; then
    pass "chezmoi_source_is_repo" "chezmoi source is within system-config repo"
  else
    skip "chezmoi_source_is_repo" "chezmoi source not yet rewired to system-config/home (deferred to end of Phase 1)"
  fi
}

check_no_repos_in_desktop_documents() {
  # Deferred check — always skip for now
  skip "no_repos_in_desktop_documents" "deferred migration check"
}

check_spotlight_exclusions_set() {
  # Phase 5 check — skip until then
  skip "spotlight_exclusions_set" "Phase 5 check"
}

run_filesystem_checks() {
  section "filesystem"
  check_xdg_dirs_exist
  check_organizations_dir_exists
  check_system_config_in_correct_location
  check_chezmoi_source_is_repo
  check_no_repos_in_desktop_documents
  check_spotlight_exclusions_set
}

# --- Category: hygiene -------------------------------------------------------

check_no_orphan_lockfiles() {
  if [[ ! -d "$SYSTEM_CONFIG_DIR" ]]; then
    skip "no_orphan_lockfiles" "system-config not found"
    return
  fi
  local locks
  locks=$(find "$SYSTEM_CONFIG_DIR" -maxdepth 2 \( -name 'package-lock.json' -o -name 'yarn.lock' -o -name 'pnpm-lock.yaml' \) 2>/dev/null | head -5)
  if [[ -z "$locks" ]]; then
    pass "no_orphan_lockfiles" "No orphan lockfiles in system-config"
  else
    fail "no_orphan_lockfiles" "Orphan lockfiles" "none" "$locks"
  fi
}

check_no_nvmrc_in_systemconfig() {
  if [[ ! -d "$SYSTEM_CONFIG_DIR" ]]; then
    skip "no_nvmrc_in_systemconfig" "system-config not found"
    return
  fi
  if [[ -f "$SYSTEM_CONFIG_DIR/.nvmrc" ]]; then
    fail "no_nvmrc_in_systemconfig" ".nvmrc" "absent" "exists in system-config"
  else
    pass "no_nvmrc_in_systemconfig" "No .nvmrc in system-config"
  fi
}

check_no_node_version_in_systemconfig() {
  if [[ ! -d "$SYSTEM_CONFIG_DIR" ]]; then
    skip "no_node_version_in_systemconfig" "system-config not found"
    return
  fi
  if [[ -f "$SYSTEM_CONFIG_DIR/.node-version" ]]; then
    fail "no_node_version_in_systemconfig" ".node-version" "absent" "exists in system-config"
  else
    pass "no_node_version_in_systemconfig" "No .node-version in system-config"
  fi
}

check_chezmoi_source_clean() {
  local src
  src=$(chezmoi source-path 2>/dev/null || echo "")
  if [[ -z "$src" ]]; then
    skip "chezmoi_source_clean" "chezmoi not configured"
    return
  fi
  if [[ ! -d "$src/.git" ]] && [[ ! -d "$(dirname "$src")/.git" ]]; then
    skip "chezmoi_source_clean" "chezmoi source is not a git repo"
    return
  fi
  local git_dir="$src"
  [[ -d "$src/.git" ]] || git_dir="$(dirname "$src")"
  local dirty
  dirty=$(git -C "$git_dir" status --porcelain 2>/dev/null | wc -l | tr -d ' ')
  if (( dirty == 0 )); then
    pass "chezmoi_source_clean" "chezmoi source repo is clean"
  else
    fail "chezmoi_source_clean" "chezmoi source" "clean" "${dirty} uncommitted changes"
  fi
}

check_git_ignorecase_false() {
  # Phase 5 check
  local val
  val=$(git config --global core.ignorecase 2>/dev/null || echo "unset")
  if [[ "$val" == "false" ]]; then
    pass "git_ignorecase_false" "git core.ignorecase is false"
  else
    skip "git_ignorecase_false" "Phase 5 check (current: ${val})"
  fi
}

run_hygiene_checks() {
  section "hygiene"
  check_no_orphan_lockfiles
  check_no_nvmrc_in_systemconfig
  check_no_node_version_in_systemconfig
  check_chezmoi_source_clean
  check_git_ignorecase_false
}

