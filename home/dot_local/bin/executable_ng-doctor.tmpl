run_category() {
  case "$1" in
    shell)      run_shell_checks ;;
    path)       run_path_checks ;;
    tools)      run_tools_checks ;;
    ssh)        run_ssh_checks ;;
    iterm2)     run_iterm2_checks ;;
    agentic)    run_agentic_checks ;;
    filesystem) run_filesystem_checks ;;
    hygiene)    run_hygiene_checks ;;
    governance) run_governance_checks ;;
    posture)    run_posture_checks ;;
    *) echo "Unknown category: $1"; exit 2 ;;
  esac
}

main() {
  echo "ng-doctor — system-config development machine verification"
  echo ""

  case "${1:-}" in
    --list)
      list_checks
      exit 0
      ;;
    --summary)
      # Run all silently, then print summary
      for cat in "${ALL_CATEGORIES[@]}"; do
        run_category "$cat" >/dev/null 2>&1 || true
      done
      printf '\nSummary: %d passed, %d failed, %d skipped\n' "$_pass" "$_fail" "$_skip"
      exit $(( _fail > 0 ? 1 : 0 ))
      ;;
    "")
      for cat in "${ALL_CATEGORIES[@]}"; do
        run_category "$cat"
      done
      ;;
    *)
      run_category "$1"
      ;;
  esac

  echo ""
  printf 'Summary: %d passed, %d failed, %d skipped\n' "$_pass" "$_fail" "$_skip"

  if (( _fail > 0 )); then
    exit 1
  fi
  exit 0
}

main "$@"
