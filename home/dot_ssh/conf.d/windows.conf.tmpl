# MAMAWORK Windows PC remote administration
# Managed by chezmoi
#
# Admin path: MacBook -> mamawork.home.arpa over LAN SSH or RDP.
# 1Password is installed on the MacBook only; the private half of
# id_ed25519_mamawork_admin.1password.pub is served by the MacBook's
# 1P SSH agent. The administrative identity is MAMAWORK\jeffr
# (Microsoft Account, member of Administrators); the legacy local
# DadAdmin account and its DadAdmin_WinNet key are deliberately
# retired by the mamawork-admin-streamline packet.
#
# HostKeyAlias 192.168.0.101 is kept while the FQDN
# mamawork.home.arpa has no known_hosts entry. A future
# mamawork-known-hosts-reconciliation packet adds the FQDN form,
# at which point this directive can be dropped.
#
# Prior placeholder Host stanzas for wyn-pc, ila-pc, axel-pc,
# bedroom-tv, and ahnie-laptop (all pointed at HostName 0.0.0.0
# with the dead ~/.ssh/dad_admin IdentityFile) were removed by the
# macbook-ssh-conf-d-streamline packet. They had no live targets
# and no working private key.

Host mamawork mamawork.home.arpa 192.168.0.101
  HostName 192.168.0.101
  User jeffr
  IdentityFile ~/.ssh/id_ed25519_mamawork_admin.1password.pub
  HostKeyAlias 192.168.0.101
