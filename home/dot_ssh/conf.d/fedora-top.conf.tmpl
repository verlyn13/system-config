# fedora-top remote administration
# Managed by chezmoi
#
# Admin path: MacBook -> fedora-top.home.arpa over LAN SSH.
# 1Password is installed on the MacBook only; the private half of
# id_ed25519_personal.1password.pub is served by the MacBook's 1P
# SSH agent (configured globally in ~/.ssh/config).
#
# Keepalive: ServerAliveInterval=30 + ServerAliveCountMax=3 means
# the MacBook sends a keepalive every 30 s and gives up after 3
# missed responses, catching dead transports in ~90 s instead of
# waiting for the OS TCP timeout. Less critical on AC now that
# /etc/systemd/logind.conf.d/20-jefahnierocks-no-suspend.conf keeps
# the laptop awake when plugged in (per
# docs/device-admin/fedora-top-power-policy-apply-2026-05-15.md);
# still useful for battery suspends.

Host fedora-top fedora-top.home.arpa 192.168.0.206
  HostName 192.168.0.206
  User verlyn13
  IdentityFile ~/.ssh/id_ed25519_personal.1password.pub
  ServerAliveInterval 30
  ServerAliveCountMax 3
  TCPKeepAlive yes
