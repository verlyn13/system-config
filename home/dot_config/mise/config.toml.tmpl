# Global mise configuration for development environment (chezmoi-managed)

[tools]
node = "{{ .versions.node | default "24" }}"
bun = "latest"
python = "{{ .versions.python | default "3.13" }}"
# go = "latest"
# rust = "stable"  # Commented out - install with: mise install rust@stable
{{ if .android -}}
java = "{{ .versions.java | default "temurin-21" }}"
{{ else -}}
# java = "{{ .versions.java | default "temurin-21" }}"
{{ end -}}
uv = "latest"
"npm:tsx" = "latest"

[settings]
# Keep experimental features enabled for task runner and direnv integration
experimental = true
# Trust common development roots so mise doesn't prompt repeatedly
trusted_config_paths = [
  "~/Repos/**",
  "~/ai/**"
]
# Prefer mise-native files over legacy managers by default
legacy_version_file = false
# Silence future deprecation by explicitly enabling idiomatic files
# (.nvmrc, .node-version, .python-version, etc.) for these tools
idiomatic_version_file_enable_tools = ["node", "python", "ruby"]
# Keep plugin autoupdate checks reasonable and builds snappy
plugin_autoupdate_last_check_duration = "7d"
jobs = 8

[env]
MISE_FISH_AUTO_ACTIVATE = "1"
MISE_LOG_LEVEL = "info"
MISE_EXPERIMENTAL = "1"
EDITOR = "nvim"
VISUAL = "nvim"
MAKEFLAGS = "-j10"
CARGO_BUILD_JOBS = "10"
NODE_OPTIONS = "--max-old-space-size=4096"
BUN_INSTALL = "~/.bun"
GOPATH = "~/.local/share/go/workspace"

