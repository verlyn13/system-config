# 15-coreutil-aliases.zsh — Modern replacements for coreutils (human shell only)
# GATE: interactive-only (skipped when NG_MODE=agentic)

[[ "$NG_MODE" == "agentic" ]] && return 0

{{- range $cmd, $expansion := .coreutil_aliases }}
command -v {{ $expansion | splitList " " | first }} &>/dev/null && alias {{ $cmd }}='{{ $expansion }}'
{{- end }}

# Enhanced ls (eza replaces ls for humans)
if command -v eza &>/dev/null; then
  alias ls='eza --icons --group-directories-first'
  alias ll='eza -la --icons --group-directories-first --git'
  alias lt='eza -T --icons -L 2'
fi
