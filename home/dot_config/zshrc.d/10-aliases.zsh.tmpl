# 10-aliases.zsh — Shell aliases that do NOT shadow POSIX commands
# GATE: always

{{- range $cmd, $expansion := .aliases }}
alias {{ $cmd }}='{{ $expansion }}'
{{- end }}

# Git shortcuts
alias gs='git status'
alias gd='git diff'
alias gds='git diff --staged'
alias ga='git add'
alias gc='git commit'
alias gp='git push'
alias gpl='git pull'
alias gco='git checkout'
alias gcb='git checkout -b'
alias gb='git branch'
alias glog='git log --oneline --graph --all'

# Navigation
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias c='clear'
