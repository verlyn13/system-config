# 00-xdg.fish — XDG exports

set -q XDG_CONFIG_HOME; or set -gx XDG_CONFIG_HOME {{ .xdg.config_home }}
set -q XDG_DATA_HOME; or set -gx XDG_DATA_HOME {{ .xdg.data_home }}
set -q XDG_STATE_HOME; or set -gx XDG_STATE_HOME {{ .xdg.state_home }}
set -q XDG_CACHE_HOME; or set -gx XDG_CACHE_HOME {{ .xdg.cache_home }}
