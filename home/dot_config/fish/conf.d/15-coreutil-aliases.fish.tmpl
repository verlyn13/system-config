# 15-coreutil-aliases.fish — Coreutil replacements (human only)
# Fish is human-only shell, but this file exists for parity and
# so the structure matches zshrc.d/ for maintainability.
#
# NOTE: grep→rg alias intentionally omitted in Fish.
# iTerm2 shell integration uses `grep -cvE` internally,
# and rg doesn't support grep's -E flag. The alias would
# break shell integration at source time.

if status is-interactive
    if type -q bat
        alias cat 'bat --paging=never'
    end

    if type -q fd
        alias find 'fd'
    end

    # Enhanced ls
    if type -q eza
        alias ls 'eza --icons --group-directories-first'
        alias ll 'eza -lah --icons --group-directories-first --git'
        alias la 'eza -a --icons --group-directories-first'
        alias lt 'eza -T --icons --group-directories-first'
    end
end
