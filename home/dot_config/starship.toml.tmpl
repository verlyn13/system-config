# Starship prompt configuration (chezmoi-managed)
# Minimal, fast, and informative; compatible with starship >=1.17 (format string grammar)

format = """
$username\
$hostname\
$directory\
$git_branch\
$git_status\
$cmd_duration\
$line_break\
$character"""

[aws]
disabled = true

[gcloud]
disabled = true

[nodejs]
disabled = true

[package]
disabled = true

[directory]
style = "blue bold"
truncation_length = 3
truncate_to_repo = true
format = "[$path]($style) "

[git_branch]
style = "green bold"
symbol = " "
format = "[$symbol$branch]($style) "

[git_status]
style = "red bold"
format = '([$all_status$ahead_behind]($style) )'
conflicted = "="
ahead = "⇡"
behind = "⇣"
diverged = "⇕"
untracked = "?"
stashed = '\$'
modified = "!"
staged = "+"
renamed = "»"
deleted = "✘"

[cmd_duration]
min_time = 2000
format = "took [$duration](bold yellow) "

[character]
success_symbol = "[❯](bold green)"
error_symbol = "[❯](bold red)"

[username]
style_user = "green bold"
style_root = "red bold"
format = "[$user]($style) "
disabled = false
show_always = false

[hostname]
ssh_only = true
format = "[$hostname](bold red) "
disabled = false

