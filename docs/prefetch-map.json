{
  "version": 1,
  "endpoints": [
    {
      "path": "/api/discovery/services",
      "ttl_seconds": 15,
      "stale_while_revalidate_seconds": 60,
      "notes": "Small payload, changes infrequently; safe to cache briefly."
    },
    {
      "path": "/api/projects",
      "ttl_seconds": 10,
      "stale_while_revalidate_seconds": 30,
      "notes": "Project list with rollups; use conditional GET via ETag."
    },
    {
      "path": "/api/discovery/schemas",
      "ttl_seconds": 0,
      "notes": "ETag provided; prefer conditional GETs."
    }
  ]
}

